[alias]
    # graph: aesthetic log with relative dates
    l = "log --graph --pretty=format:'%C(#CDD6F4)%h%C(reset) -%C(#CDD6F4)%d%C(reset) %s %C(#CDD6F4)(%cr)%C(reset) %C(#87B0F9)<%an>%C(reset)' --abbrev-commit"

    # reflog: head movement tracking
    rf = "reflog --pretty=format:'%C(#CDD6F4)%h%C(reset) %C(cyan)%gd%C(reset) %gs %C(#CDD6F4)(%cr)%C(reset)'"

    # show: word-level diff with flavor colors
    sh = "show --pretty=format:'%C(#CDD6F4)%h%C(reset) %s %C(#87B0F9)<%an>%C(reset)' --color-words"
    