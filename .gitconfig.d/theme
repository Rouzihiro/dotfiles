[alias]
    # graph: aesthetic log with relative dates
    l = "log --graph --pretty=format:'%C(#6fb8e3)%h%C(reset) -%C(#6fb8e3)%d%C(reset) %s %C(#6fb8e3)(%cr)%C(reset) %C(#5e95bc)<%an>%C(reset)' --abbrev-commit"

    # reflog: head movement tracking
    rf = "reflog --pretty=format:'%C(#6fb8e3)%h%C(reset) %C(cyan)%gd%C(reset) %gs %C(#6fb8e3)(%cr)%C(reset)'"

    # show: word-level diff with flavor colors
    sh = "show --pretty=format:'%C(#6fb8e3)%h%C(reset) %s %C(#5e95bc)<%an>%C(reset)' --color-words"
    