[alias]
    # graph: aesthetic log with relative dates
    l = "log --graph --pretty=format:'%C(#a89984)%h%C(reset) -%C(#a89984)%d%C(reset) %s %C(#a89984)(%cr)%C(reset) %C(#458588)<%an>%C(reset)' --abbrev-commit"

    # reflog: head movement tracking
    rf = "reflog --pretty=format:'%C(#a89984)%h%C(reset) %C(cyan)%gd%C(reset) %gs %C(#a89984)(%cr)%C(reset)'"

    # show: word-level diff with flavor colors
    sh = "show --pretty=format:'%C(#a89984)%h%C(reset) %s %C(#458588)<%an>%C(reset)' --color-words"
    