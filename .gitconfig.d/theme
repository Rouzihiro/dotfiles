[alias]
    # graph: aesthetic log with relative dates
    l = "log --graph --pretty=format:'%C(#6f8fa3)%h%C(reset) -%C(#6f8fa3)%d%C(reset) %s %C(#6f8fa3)(%cr)%C(reset) %C(#8a9a7b)<%an>%C(reset)' --abbrev-commit"

    # reflog: head movement tracking
    rf = "reflog --pretty=format:'%C(#6f8fa3)%h%C(reset) %C(cyan)%gd%C(reset) %gs %C(#6f8fa3)(%cr)%C(reset)'"

    # show: word-level diff with flavor colors
    sh = "show --pretty=format:'%C(#6f8fa3)%h%C(reset) %s %C(#8a9a7b)<%an>%C(reset)' --color-words"
    