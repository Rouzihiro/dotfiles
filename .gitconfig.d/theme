[alias]
    # graph: aesthetic log with relative dates
    l = "log --graph --pretty=format:'%C(#7ab0df)%h%C(reset) -%C(#7ab0df)%d%C(reset) %s %C(#7ab0df)(%cr)%C(reset) %C(#79dcaa)<%an>%C(reset)' --abbrev-commit"

    # reflog: head movement tracking
    rf = "reflog --pretty=format:'%C(#7ab0df)%h%C(reset) %C(cyan)%gd%C(reset) %gs %C(#7ab0df)(%cr)%C(reset)'"

    # show: word-level diff with flavor colors
    sh = "show --pretty=format:'%C(#7ab0df)%h%C(reset) %s %C(#79dcaa)<%an>%C(reset)' --color-words"
    