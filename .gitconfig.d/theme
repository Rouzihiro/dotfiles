[alias]
    # graph: aesthetic log with relative dates
    l = "log --graph --pretty=format:'%C(#f38d70)%h%C(reset) -%C(#f38d70)%d%C(reset) %s %C(#f38d70)(%cr)%C(reset) %C(#adda78)<%an>%C(reset)' --abbrev-commit"

    # reflog: head movement tracking
    rf = "reflog --pretty=format:'%C(#f38d70)%h%C(reset) %C(cyan)%gd%C(reset) %gs %C(#f38d70)(%cr)%C(reset)'"

    # show: word-level diff with flavor colors
    sh = "show --pretty=format:'%C(#f38d70)%h%C(reset) %s %C(#adda78)<%an>%C(reset)' --color-words"
    