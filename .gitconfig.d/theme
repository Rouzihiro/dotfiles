[alias]
    # graph: aesthetic log with relative dates
    l = "log --graph --pretty=format:'%C(#268BD2)%h%C(reset) -%C(#268BD2)%d%C(reset) %s %C(#268BD2)(%cr)%C(reset) %C(#859900)<%an>%C(reset)' --abbrev-commit"

    # reflog: head movement tracking
    rf = "reflog --pretty=format:'%C(#268BD2)%h%C(reset) %C(cyan)%gd%C(reset) %gs %C(#268BD2)(%cr)%C(reset)'"

    # show: word-level diff with flavor colors
    sh = "show --pretty=format:'%C(#268BD2)%h%C(reset) %s %C(#859900)<%an>%C(reset)' --color-words"
    