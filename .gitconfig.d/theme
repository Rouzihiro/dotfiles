[alias]
    # graph: aesthetic log with relative dates
    l = "log --graph --pretty=format:'%C(#bd93f9)%h%C(reset) -%C(#bd93f9)%d%C(reset) %s %C(#bd93f9)(%cr)%C(reset) %C(#50fa7b)<%an>%C(reset)' --abbrev-commit"

    # reflog: head movement tracking
    rf = "reflog --pretty=format:'%C(#bd93f9)%h%C(reset) %C(cyan)%gd%C(reset) %gs %C(#bd93f9)(%cr)%C(reset)'"

    # show: word-level diff with flavor colors
    sh = "show --pretty=format:'%C(#bd93f9)%h%C(reset) %s %C(#50fa7b)<%an>%C(reset)' --color-words"
    