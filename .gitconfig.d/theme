[alias]
    # graph: aesthetic log with relative dates
    l = "log --graph --pretty=format:'%C(#3c3836)%h%C(reset) -%C(#3c3836)%d%C(reset) %s %C(#3c3836)(%cr)%C(reset) %C(#cc241d)<%an>%C(reset)' --abbrev-commit"

    # reflog: head movement tracking
    rf = "reflog --pretty=format:'%C(#3c3836)%h%C(reset) %C(cyan)%gd%C(reset) %gs %C(#3c3836)(%cr)%C(reset)'"

    # show: word-level diff with flavor colors
    sh = "show --pretty=format:'%C(#3c3836)%h%C(reset) %s %C(#cc241d)<%an>%C(reset)' --color-words"
    