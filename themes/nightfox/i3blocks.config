# Global properties
separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#cdcecf

[separator]
full_text="⟨"
color=#575860

[bandwidth]
command=bandwith
interval=1
label=   
color=#81b29a

[separator]
full_text="⟨"
color=#575860

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#86abdc

[separator]
full_text="⟨"
color=#575860

[memory]
label=  
command=memory
interval=2
color=#86abdc

[separator]
full_text="⟨"
color=#575860

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#c94f6d

[separator]
full_text="⟨"
color=#575860

[wifi]
command=wifi-status
interval=30
color=#cdcecf

[separator]
full_text="⟨"
color=#575860

[volume]
command=wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{if ($3 == "[MUTED]") print "MUTED"; else print int($2 * 100) " %"}'
interval=1
label=   
color=#e0c989

[separator]
full_text="⟨"
color=#575860

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#cdcecf

[separator]
full_text="⟨"
color=#575860

[brightness]
command=brightnessctl g | awk '{print $1}'
interval=5
label=   
color=#cdcecf

[separator]
full_text="⟨"
color=#575860

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#86abdc

[separator]
full_text="⟨"
color=#575860

[keymap]
command=kb-layout
interval=2
color=#86abdc

[separator]
full_text="⟨"
color=#575860

[battery]
command=battery
interval=30
color=#81b29a

[separator]
full_text="⟨"
color=#575860

[shutdown_menu]
full_text=
command=powermenu
color=#c94f6d
