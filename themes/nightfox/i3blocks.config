separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#cdcecf

[separator]
full_text="⟨"
color=#343c47

[bandwidth]
command=bandwith
interval=1
label=   
color=#63cdcf

[separator]
full_text="⟨"
color=#343c47

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#719cd6

[separator]
full_text="⟨"
color=#343c47

[memory]
label=  
command=memory
interval=2
color=#719cd6

[separator]
full_text="⟨"
color=#343c47

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#c94f6d

[separator]
full_text="⟨"
color=#343c47

[wifi]
command=wifi-status
interval=30
color=#cdcecf

[separator]
full_text="⟨"
color=#343c47

[volume]
command=sb-volume
interval=1
color=#dbc074

[separator]
full_text="⟨"
color=#343c47

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#cdcecf

[separator]
full_text="⟨"
color=#343c47

[brightness]
command=sb-brightness
interval=5
label=   
color=#cdcecf

[separator]
full_text="⟨"
color=#343c47

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#719cd6

[separator]
full_text="⟨"
color=#343c47

[keymap]
command=kb-layout
interval=2
color=#719cd6

[separator]
full_text="⟨"
color=#343c47

[battery]
command=battery
interval=30
color=#63cdcf

[separator]
full_text="⟨"
color=#343c47

[shutdown_menu]
full_text=
command=powermenu
color=#c94f6d
