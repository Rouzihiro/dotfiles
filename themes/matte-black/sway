# Generated from kitty.conf

# Default foreground
set $fujiWhite      #e0e0e0

# Dark foreground (statuslines)
set $oldWhite       #e0e0e0

# Dark background (statuslines and floating windows)
set $sumiInk0       #080808

# Default background
set $sumiInk1       #121212

# Lighter background (colorcolumn, folds)
set $sumiInk2       #4d4d4d

# Lighter background (cursorline)
set $sumiInk3       #4d4d4d

# Darker foreground (line numbers, fold column, non-text characters), float borders
set $sumiInk4       #4d4d4d

# Popup background, visual selection background
set $waveBlue1      #7ab0df

# Popup selection background, search background
set $waveBlue2      #7ab0df

# Diff Add (background)
set $winterGreen    #79dcaa

# Diff Change (background)
set $winterYellow   #ffe16b

# Diff Deleted (background)
set $winterRed      #f87070

# Diff Line (background)
set $winterBlue     #7ab0df

# Git Add
set $autumnGreen    #79dcaa

# Git Delete
set $autumnRed      #f87070

# Git Change
set $autumnYellow   #ffe16b

# Diagnostic Error
set $samuraiRed     #f87070

# Diagnostic Warning
set $roninYellow    #ffe16b

# Diagnostic Info
set $waveAqua1      #7ab0df

# Diagnostic Hint
set $dragonBlue     #7ab0df

# Comments
set $fujiGray       #4d4d4d

# Light foreground
set $springViolet1  #e0e0e0

# Statements and Keywords
set $oniViolet      #ae81ff

# Functions and Titles
set $crystalBlue    #7ab0df

# Brackets and punctuation
set $springViolet2  #ae81ff

# Specials and builtin functions
set $springBlue     #7ab0df

# Not used (assigned Nightfox-consistent shades)
set $lightBlue      #70c0ba
set $boatYellow1    #ffe16b

# Types
set $waveAqua2      #70c0ba

# Strings
set $springGreen    #79dcaa

# Operators, RegEx
set $boatYellow2    #ffe16b

# Identifiers
set $carpYellow     #ffe16b

# Numbers
set $sakuraPink     #ae81ff

# Standout specials 1 (builtin variables)
set $waveRed        #f87070

# Standout specials 2 (exception handling, return)
set $peachRed       #f87070

# Constants, imports, booleans
set $surimiOrange   #ffe16b

# Deprecated
set $katanaGray     #4d4d4d
