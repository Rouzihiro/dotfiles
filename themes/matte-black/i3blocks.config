# Global properties
separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#e0e0e0

[separator]
full_text="⟨"
color=#4d4d4d

[bandwidth]
command=bandwith
interval=1
label=   
color=#79dcaa

[separator]
full_text="⟨"
color=#4d4d4d

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#7ab0df

[separator]
full_text="⟨"
color=#4d4d4d

[memory]
label=  
command=memory
interval=2
color=#7ab0df

[separator]
full_text="⟨"
color=#4d4d4d

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#f87070

[separator]
full_text="⟨"
color=#4d4d4d

[wifi]
command=wifi-status
interval=30
color=#e0e0e0

[separator]
full_text="⟨"
color=#4d4d4d

[volume]
command=wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{if ($3 == "[MUTED]") print "MUTED"; else print int($2 * 100) " %"}'
interval=1
label=   
color=#ff8f40

[separator]
full_text="⟨"
color=#4d4d4d

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#e0e0e0

[separator]
full_text="⟨"
color=#4d4d4d

[brightness]
command=brightnessctl g | awk '{print $1}'
interval=5
label=   
color=#e0e0e0

[separator]
full_text="⟨"
color=#4d4d4d

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#7ab0df

[separator]
full_text="⟨"
color=#4d4d4d

[keymap]
command=kb-layout
interval=2
color=#7ab0df

[separator]
full_text="⟨"
color=#4d4d4d

[battery]
command=battery
interval=30
color=#79dcaa

[separator]
full_text="⟨"
color=#4d4d4d

[shutdown_menu]
full_text=
command=powermenu
color=#f87070
