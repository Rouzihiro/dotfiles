separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#f8f8f2

[separator]
full_text="⟨"
color=#474852

[bandwidth]
command=bandwith
interval=1
label=   
color=#8be9fd

[separator]
full_text="⟨"
color=#474852

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#bd93f9

[separator]
full_text="⟨"
color=#474852

[memory]
label=  
command=memory
interval=2
color=#bd93f9

[separator]
full_text="⟨"
color=#474852

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#ff5555

[separator]
full_text="⟨"
color=#474852

[wifi]
command=wifi-status
interval=30
color=#f8f8f2

[separator]
full_text="⟨"
color=#474852

[volume]
command=sb-volume
interval=1
color=#f1fa8c

[separator]
full_text="⟨"
color=#474852

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#f8f8f2

[separator]
full_text="⟨"
color=#474852

[brightness]
command=sb-brightness
interval=5
label=   
color=#f8f8f2

[separator]
full_text="⟨"
color=#474852

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#bd93f9

[separator]
full_text="⟨"
color=#474852

[keymap]
command=kb-layout
interval=2
color=#bd93f9

[separator]
full_text="⟨"
color=#474852

[battery]
command=battery
interval=30
color=#8be9fd

[separator]
full_text="⟨"
color=#474852

[shutdown_menu]
full_text=
command=powermenu
color=#ff5555
