# Generated from kitty.conf

# Default foreground
set $fujiWhite      #f8f8f2

# Dark foreground (statuslines)
set $oldWhite       #f8f8f2

# Dark background (statuslines and floating windows)
set $sumiInk0       #21222c

# Default background
set $sumiInk1       #282a36

# Lighter background (colorcolumn, folds)
set $sumiInk2       #6272a4

# Lighter background (cursorline)
set $sumiInk3       #6272a4

# Darker foreground (line numbers, fold column, non-text characters), float borders
set $sumiInk4       #6272a4

# Popup background, visual selection background
set $waveBlue1      #bd93f9

# Popup selection background, search background
set $waveBlue2      #bd93f9

# Diff Add (background)
set $winterGreen    #50fa7b

# Diff Change (background)
set $winterYellow   #f1fa8c

# Diff Deleted (background)
set $winterRed      #ff5555

# Diff Line (background)
set $winterBlue     #bd93f9

# Git Add
set $autumnGreen    #50fa7b

# Git Delete
set $autumnRed      #ff5555

# Git Change
set $autumnYellow   #f1fa8c

# Diagnostic Error
set $samuraiRed     #ff5555

# Diagnostic Warning
set $roninYellow    #f1fa8c

# Diagnostic Info
set $waveAqua1      #bd93f9

# Diagnostic Hint
set $dragonBlue     #bd93f9

# Comments
set $fujiGray       #6272a4

# Light foreground
set $springViolet1  #f8f8f2

# Statements and Keywords
set $oniViolet      #ff79c6

# Functions and Titles
set $crystalBlue    #bd93f9

# Brackets and punctuation
set $springViolet2  #ff79c6

# Specials and builtin functions
set $springBlue     #bd93f9

# Not used (assigned Nightfox-consistent shades)
set $lightBlue      #8be9fd
set $boatYellow1    #f1fa8c

# Types
set $waveAqua2      #8be9fd

# Strings
set $springGreen    #50fa7b

# Operators, RegEx
set $boatYellow2    #f1fa8c

# Identifiers
set $carpYellow     #f1fa8c

# Numbers
set $sakuraPink     #ff79c6

# Standout specials 1 (builtin variables)
set $waveRed        #ff5555

# Standout specials 2 (exception handling, return)
set $peachRed       #ff5555

# Deprecated
set $katanaGray     #6272a4
