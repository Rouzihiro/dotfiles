# Global properties
separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#b4d0dd

[separator]
full_text="⟨"
color=#63666c

[bandwidth]
command=bandwith
interval=1
label=   
color=#bbcce7

[separator]
full_text="⟨"
color=#63666c

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#a4e2ff

[separator]
full_text="⟨"
color=#63666c

[memory]
label=  
command=memory
interval=2
color=#a4e2ff

[separator]
full_text="⟨"
color=#63666c

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#6e7b91

[separator]
full_text="⟨"
color=#63666c

[wifi]
command=wifi-status
interval=30
color=#b4d0dd

[separator]
full_text="⟨"
color=#63666c

[volume]
command=wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{if ($3 == "[MUTED]") print "MUTED"; else print int($2 * 100) " %"}'
interval=1
label=   
color=#a1bbcf

[separator]
full_text="⟨"
color=#63666c

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#b4d0dd

[separator]
full_text="⟨"
color=#63666c

[brightness]
command=brightnessctl g | awk '{print $1}'
interval=5
label=   
color=#b4d0dd

[separator]
full_text="⟨"
color=#63666c

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#a4e2ff

[separator]
full_text="⟨"
color=#63666c

[keymap]
command=kb-layout
interval=2
color=#a4e2ff

[separator]
full_text="⟨"
color=#63666c

[battery]
command=battery
interval=30
color=#bbcce7

[separator]
full_text="⟨"
color=#63666c

[shutdown_menu]
full_text=
command=powermenu
color=#6e7b91
