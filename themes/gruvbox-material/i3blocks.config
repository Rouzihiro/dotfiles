separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#d4be98

[separator]
full_text="⟨"
color=#413e38

[bandwidth]
command=bandwith
interval=1
label=   
color=#89b482

[separator]
full_text="⟨"
color=#413e38

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#458588

[separator]
full_text="⟨"
color=#413e38

[memory]
label=  
command=memory
interval=2
color=#458588

[separator]
full_text="⟨"
color=#413e38

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#ea6962

[separator]
full_text="⟨"
color=#413e38

[wifi]
command=wifi-status
interval=30
color=#d4be98

[separator]
full_text="⟨"
color=#413e38

[volume]
command=sb-volume
interval=1
color=#d8a657

[separator]
full_text="⟨"
color=#413e38

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#d4be98

[separator]
full_text="⟨"
color=#413e38

[brightness]
command=sb-brightness
interval=5
label=   
color=#d4be98

[separator]
full_text="⟨"
color=#413e38

[time]
interval=1
command=timer
