separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#c0caf5

[separator]
full_text="⟨"
color=#323545

[bandwidth]
command=bandwith
interval=1
label=   
color=#7dcfff

[separator]
full_text="⟨"
color=#323545

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#7aa2f7

[separator]
full_text="⟨"
color=#323545

[memory]
label=  
command=memory
interval=2
color=#7aa2f7

[separator]
full_text="⟨"
color=#323545

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#f7768e

[separator]
full_text="⟨"
color=#323545

[wifi]
command=wifi-status
interval=30
color=#c0caf5

[separator]
full_text="⟨"
color=#323545

[volume]
command=sb-volume
interval=1
color=#e0af68

[separator]
full_text="⟨"
color=#323545

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#c0caf5

[separator]
full_text="⟨"
color=#323545

[brightness]
command=sb-brightness
interval=5
label=   
color=#c0caf5

[separator]
full_text="⟨"
color=#323545

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#7aa2f7

[separator]
full_text="⟨"
color=#323545

[keymap]
command=kb-layout
interval=2
color=#7aa2f7

[separator]
full_text="⟨"
color=#323545

[battery]
command=battery
interval=30
color=#7dcfff

[separator]
full_text="⟨"
color=#323545

[shutdown_menu]
full_text=
command=powermenu
color=#f7768e
