# Generated from kitty.conf

# Default foreground
set $fujiWhite      #c0caf5

# Dark foreground (statuslines)
set $oldWhite       #a9b1d6

# Dark background (statuslines and floating windows)
set $sumiInk0       #15161e

# Default background
set $sumiInk1       #1a1b26

# Lighter background (colorcolumn, folds)
set $sumiInk2       #414868

# Lighter background (cursorline)
set $sumiInk3       #414868

# Darker foreground (line numbers, fold column, non-text characters), float borders
set $sumiInk4       #414868

# Popup background, visual selection background
set $waveBlue1      #7aa2f7

# Popup selection background, search background
set $waveBlue2      #7aa2f7

# Diff Add (background)
set $winterGreen    #9ece6a

# Diff Change (background)
set $winterYellow   #e0af68

# Diff Deleted (background)
set $winterRed      #f7768e

# Diff Line (background)
set $winterBlue     #7aa2f7

# Git Add
set $autumnGreen    #9ece6a

# Git Delete
set $autumnRed      #f7768e

# Git Change
set $autumnYellow   #e0af68

# Diagnostic Error
set $samuraiRed     #f7768e

# Diagnostic Warning
set $roninYellow    #e0af68

# Diagnostic Info
set $waveAqua1      #7aa2f7

# Diagnostic Hint
set $dragonBlue     #7aa2f7

# Comments
set $fujiGray       #414868

# Light foreground
set $springViolet1  #a9b1d6

# Statements and Keywords
set $oniViolet      #bb9af7

# Functions and Titles
set $crystalBlue    #7aa2f7

# Brackets and punctuation
set $springViolet2  #bb9af7

# Specials and builtin functions
set $springBlue     #7aa2f7

# Not used (assigned Nightfox-consistent shades)
