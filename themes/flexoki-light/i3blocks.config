separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#100F0F

[separator]
full_text="⟨"
color=#dbd8ce

[bandwidth]
command=bandwith
interval=1
label=   
color=#3AA99F

[separator]
full_text="⟨"
color=#dbd8ce

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#4385BE

[separator]
full_text="⟨"
color=#dbd8ce

[memory]
label=  
command=memory
interval=2
color=#4385BE

[separator]
full_text="⟨"
color=#dbd8ce

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#D14D41

[separator]
full_text="⟨"
color=#dbd8ce

[wifi]
command=wifi-status
interval=30
color=#100F0F

[separator]
full_text="⟨"
color=#dbd8ce

[volume]
command=sb-volume
interval=1
color=#D0A215

[separator]
full_text="⟨"
color=#dbd8ce

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#100F0F

[separator]
full_text="⟨"
color=#dbd8ce

[brightness]
command=sb-brightness
interval=5
label=   
color=#100F0F

[separator]
full_text="⟨"
color=#dbd8ce

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#4385BE

[separator]
full_text="⟨"
color=#dbd8ce

[keymap]
command=kb-layout
interval=2
color=#4385BE

[separator]
full_text="⟨"
color=#dbd8ce

[battery]
command=battery
interval=30
color=#3AA99F

[separator]
full_text="⟨"
color=#dbd8ce

[shutdown_menu]
full_text=
command=powermenu
color=#D14D41
