# Global properties
separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#100F0F

[separator]
full_text="⟨"
color=#F2F0E5

[bandwidth]
command=bandwith
interval=1
label=   
color=#AD8301

[separator]
full_text="⟨"
color=#F2F0E5

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#205EA6

[separator]
full_text="⟨"
color=#F2F0E5

[memory]
label=  
command=memory
interval=2
color=#205EA6

[separator]
full_text="⟨"
color=#F2F0E5

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#D14D41

[separator]
full_text="⟨"
color=#F2F0E5

[wifi]
command=wifi-status
interval=30
color=#100F0F

[separator]
full_text="⟨"
color=#F2F0E5

[volume]
command=wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{if ($3 == "[MUTED]") print "MUTED"; else print int($2 * 100) " %"}'
interval=1
label=   
color=#AD8301

[separator]
full_text="⟨"
color=#F2F0E5

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#100F0F

[separator]
full_text="⟨"
color=#F2F0E5

[brightness]
command=brightnessctl g | awk '{print $1}'
interval=5
label=   
color=#100F0F

[separator]
full_text="⟨"
color=#F2F0E5

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#205EA6

[separator]
full_text="⟨"
color=#F2F0E5

[keymap]
command=kb-layout
interval=2
color=#205EA6

[separator]
full_text="⟨"
color=#F2F0E5

[battery]
command=battery
interval=30
color=#AD8301

[separator]
full_text="⟨"
color=#F2F0E5

[shutdown_menu]
full_text=
command=powermenu
color=#D14D41
