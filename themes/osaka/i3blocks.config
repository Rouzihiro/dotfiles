separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#C1C497

[separator]
full_text="⟨"
color=#2b352b

[bandwidth]
command=bandwith
interval=1
label=   
color=#2DD5B7

[separator]
full_text="⟨"
color=#2b352b

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#509475

[separator]
full_text="⟨"
color=#2b352b

[memory]
label=  
command=memory
interval=2
color=#509475

[separator]
full_text="⟨"
color=#2b352b

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#FF5345

[separator]
full_text="⟨"
color=#2b352b

[wifi]
command=wifi-status
interval=30
color=#C1C497

[separator]
full_text="⟨"
color=#2b352b

[volume]
command=sb-volume
interval=1
color=#459451

[separator]
full_text="⟨"
color=#2b352b

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#C1C497

[separator]
full_text="⟨"
color=#2b352b

[brightness]
command=sb-brightness
interval=5
label=   
color=#C1C497

[separator]
full_text="⟨"
color=#2b352b

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#509475

[separator]
full_text="⟨"
color=#2b352b

[keymap]
command=kb-layout
interval=2
color=#509475

[separator]
full_text="⟨"
color=#2b352b

[battery]
command=battery
interval=30
color=#2DD5B7

[separator]
full_text="⟨"
color=#2b352b

[shutdown_menu]
full_text=
command=powermenu
color=#FF5345
