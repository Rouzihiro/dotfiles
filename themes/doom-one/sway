# Generated from kitty.conf

# Default foreground
set $fujiWhite      #bbc2cf

# Dark foreground (statuslines)
set $oldWhite       #bbc2cf

# Dark background (statuslines and floating windows)
set $sumiInk0       #000000

# Default background
set $sumiInk1       #282c34

# Lighter background (colorcolumn, folds)
set $sumiInk2       #595959

# Lighter background (cursorline)
set $sumiInk3       #595959

# Darker foreground (line numbers, fold column, non-text characters), float borders
set $sumiInk4       #595959

# Popup background, visual selection background
set $waveBlue1      #a9a1e1

# Popup selection background, search background
set $waveBlue2      #a9a1e1

# Diff Add (background)
set $winterGreen    #98be65

# Diff Change (background)
set $winterYellow   #ecbe7b

# Diff Deleted (background)
set $winterRed      #ff6c6b

# Diff Line (background)
set $winterBlue     #a9a1e1

# Git Add
set $autumnGreen    #98be65

# Git Delete
set $autumnRed      #ff6c6b

# Git Change
set $autumnYellow   #ecbe7b

# Diagnostic Error
set $samuraiRed     #ff6c6b

# Diagnostic Warning
set $roninYellow    #ecbe7b

# Diagnostic Info
set $waveAqua1      #a9a1e1

# Diagnostic Hint
set $dragonBlue     #a9a1e1

# Comments
set $fujiGray       #595959

# Light foreground
set $springViolet1  #bbc2cf

# Statements and Keywords
set $oniViolet      #c678dd

# Functions and Titles
set $crystalBlue    #a9a1e1

# Brackets and punctuation
set $springViolet2  #c678dd

# Specials and builtin functions
set $springBlue     #a9a1e1

# Not used (assigned Nightfox-consistent shades)
set $lightBlue      #51afef
set $boatYellow1    #ecbe7b

# Types
set $waveAqua2      #51afef

# Strings
set $springGreen    #98be65

# Operators, RegEx
set $boatYellow2    #ecbe7b

# Identifiers
set $carpYellow     #ecbe7b

# Numbers
set $sakuraPink     #c678dd

# Standout specials 1 (builtin variables)
set $waveRed        #ff6c6b

# Standout specials 2 (exception handling, return)
set $peachRed       #ff6c6b

# Constants, imports, booleans
set $surimiOrange   

# Deprecated
set $katanaGray     #595959
