separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#ffcead

[separator]
full_text="⟨"
color=#2b2833

[bandwidth]
command=bandwith
interval=1
label=   
color=#a3bfd1

[separator]
full_text="⟨"
color=#2b2833

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#7d82d9

[separator]
full_text="⟨"
color=#2b2833

[memory]
label=  
command=memory
interval=2
color=#7d82d9

[separator]
full_text="⟨"
color=#2b2833

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#ED5B5A

[separator]
full_text="⟨"
color=#2b2833

[wifi]
command=wifi-status
interval=30
color=#ffcead

[separator]
full_text="⟨"
color=#2b2833

[volume]
command=sb-volume
interval=1
color=#E9BB4F

[separator]
full_text="⟨"
color=#2b2833

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#ffcead

[separator]
full_text="⟨"
color=#2b2833

[brightness]
command=sb-brightness
interval=5
label=   
color=#ffcead

[separator]
full_text="⟨"
color=#2b2833

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#7d82d9

[separator]
full_text="⟨"
color=#2b2833

[keymap]
command=kb-layout
interval=2
color=#7d82d9

[separator]
full_text="⟨"
color=#2b2833

[battery]
command=battery
interval=30
color=#a3bfd1

[separator]
full_text="⟨"
color=#2b2833

[shutdown_menu]
full_text=
command=powermenu
color=#ED5B5A
