separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#cdd6f4

[separator]
full_text="⟨"
color=#2d2e3b

[bandwidth]
command=bandwith
interval=1
label=   
color=#94e2d5

[separator]
full_text="⟨"
color=#2d2e3b

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#89b4fa

[separator]
full_text="⟨"
color=#2d2e3b

[memory]
label=  
command=memory
interval=2
color=#89b4fa

[separator]
full_text="⟨"
color=#2d2e3b

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#f38ba8

[separator]
full_text="⟨"
color=#2d2e3b

[wifi]
command=wifi-status
interval=30
color=#cdd6f4

[separator]
full_text="⟨"
color=#2d2e3b

[volume]
command=sb-volume
interval=1
color=#f9e2af

[separator]
full_text="⟨"
color=#2d2e3b

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#cdd6f4

[separator]
full_text="⟨"
color=#2d2e3b

[brightness]
command=sb-brightness
interval=5
label=   
color=#cdd6f4

[separator]
full_text="⟨"
color=#2d2e3b

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#89b4fa

[separator]
full_text="⟨"
color=#2d2e3b

[keymap]
command=kb-layout
interval=2
color=#89b4fa

[separator]
full_text="⟨"
color=#2d2e3b

[battery]
command=battery
interval=30
color=#94e2d5

[separator]
full_text="⟨"
color=#2d2e3b

[shutdown_menu]
full_text=
command=powermenu
color=#f38ba8
