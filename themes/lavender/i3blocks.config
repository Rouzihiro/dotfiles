# Global properties
separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#cdd6f4

[separator]
full_text="⟨"
color=#585b70

[bandwidth]
command=bandwith
interval=1
label=   
color=#a6e3a1

[separator]
full_text="⟨"
color=#585b70

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#cba6f7

[separator]
full_text="⟨"
color=#585b70

[memory]
label=  
command=memory
interval=2
color=#cba6f7

[separator]
full_text="⟨"
color=#585b70

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#f38ba8

[separator]
full_text="⟨"
color=#585b70

[wifi]
command=wifi-status
interval=30
color=#cdd6f4

[separator]
full_text="⟨"
color=#585b70

[volume]
command=sb-volume
interval=1
color=#fab387

[separator]
full_text="⟨"
color=#585b70

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#cdd6f4

[separator]
full_text="⟨"
color=#585b70

[brightness]
command=sb-brightness
interval=5
label=   
color=#cdd6f4

[separator]
full_text="⟨"
color=#585b70

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#cba6f7

[separator]
full_text="⟨"
color=#585b70

[keymap]
command=kb-layout
interval=2
color=#cba6f7

[separator]
full_text="⟨"
color=#585b70

[battery]
command=battery
interval=30
color=#a6e3a1

[separator]
full_text="⟨"
color=#585b70

[shutdown_menu]
full_text=
command=powermenu
color=#f38ba8
