# Global properties
separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#4C4F69

[separator]
full_text="⟨"
color=#ACB0BE

[bandwidth]
command=bandwith
interval=1
label=   
color=#40A02B

[separator]
full_text="⟨"
color=#ACB0BE

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#4C4F69

[separator]
full_text="⟨"
color=#ACB0BE

[memory]
label=  
command=memory
interval=2
color=#4C4F69

[separator]
full_text="⟨"
color=#ACB0BE

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#D20F39

[separator]
full_text="⟨"
color=#ACB0BE

[wifi]
command=wifi-status
interval=30
color=#4C4F69

[separator]
full_text="⟨"
color=#ACB0BE

[volume]
command=sb-volume
interval=1
color=#DF8E1D

[separator]
full_text="⟨"
color=#ACB0BE

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#4C4F69

[separator]
full_text="⟨"
color=#ACB0BE

[brightness]
command=sb-brightness
interval=5
label=   
color=#4C4F69

[separator]
full_text="⟨"
color=#ACB0BE

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#4C4F69

[separator]
full_text="⟨"
color=#ACB0BE

[keymap]
command=kb-layout
interval=2
color=#4C4F69

[separator]
full_text="⟨"
color=#ACB0BE

[battery]
command=battery
interval=30
color=#40A02B

[separator]
full_text="⟨"
color=#ACB0BE

[shutdown_menu]
full_text=
command=powermenu
color=#D20F39
