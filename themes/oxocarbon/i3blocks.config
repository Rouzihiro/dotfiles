# Global properties
separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#f2f4f8

[separator]
full_text="⟨"
color=#262626

[bandwidth]
command=bandwith
interval=1
label=   
color=#3ddbd9

[separator]
full_text="⟨"
color=#262626

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#33b1ff

[separator]
full_text="⟨"
color=#262626

[memory]
label=  
command=memory
interval=2
color=#33b1ff

[separator]
full_text="⟨"
color=#262626

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#ee5396

[separator]
full_text="⟨"
color=#262626

[wifi]
command=wifi-status
interval=30
color=#f2f4f8

[separator]
full_text="⟨"
color=#262626

[volume]
command=sb-volume
interval=1
color=#82cfff

[separator]
full_text="⟨"
color=#262626

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#f2f4f8

[separator]
full_text="⟨"
color=#262626

[brightness]
command=sb-brightness
interval=5
label=   
color=#f2f4f8

[separator]
full_text="⟨"
color=#262626

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#33b1ff

[separator]
full_text="⟨"
color=#262626

[keymap]
command=kb-layout
interval=2
color=#33b1ff

[separator]
full_text="⟨"
color=#262626

[battery]
command=battery
interval=30
color=#3ddbd9

[separator]
full_text="⟨"
color=#262626

[shutdown_menu]
full_text=
command=powermenu
color=#ee5396
