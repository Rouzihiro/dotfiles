separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#CECDC3

[separator]
full_text="⟨"
color=#2c2b2a

[bandwidth]
command=bandwith
interval=1
label=   
color=#24837B

[separator]
full_text="⟨"
color=#2c2b2a

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#205EA6

[separator]
full_text="⟨"
color=#2c2b2a

[memory]
label=  
command=memory
interval=2
color=#205EA6

[separator]
full_text="⟨"
color=#2c2b2a

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#AF3029

[separator]
full_text="⟨"
color=#2c2b2a

[wifi]
command=wifi-status
interval=30
color=#CECDC3

[separator]
full_text="⟨"
color=#2c2b2a

[volume]
command=sb-volume
interval=1
color=#AD8301

[separator]
full_text="⟨"
color=#2c2b2a

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#CECDC3

[separator]
full_text="⟨"
color=#2c2b2a

[brightness]
command=sb-brightness
interval=5
label=   
color=#CECDC3

[separator]
full_text="⟨"
color=#2c2b2a

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#205EA6

[separator]
full_text="⟨"
color=#2c2b2a

[keymap]
command=kb-layout
interval=2
color=#205EA6

[separator]
full_text="⟨"
color=#2c2b2a

[battery]
command=battery
interval=30
color=#24837B

[separator]
full_text="⟨"
color=#2c2b2a

[shutdown_menu]
full_text=
command=powermenu
color=#AF3029
