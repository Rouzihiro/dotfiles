# Generated from kitty.conf

# Default foreground
set $fujiWhite      #e6d9db

# Dark foreground (statuslines)
set $oldWhite       #e6d9db

# Dark background (statuslines and floating windows)
set $sumiInk0       #72696a

# Default background
set $sumiInk1       #2c2525

# Lighter background (colorcolumn, folds)
set $sumiInk2       #948a8b

# Lighter background (cursorline)
set $sumiInk3       #948a8b

# Darker foreground (line numbers, fold column, non-text characters), float borders
set $sumiInk4       #948a8b

# Popup background, visual selection background
set $waveBlue1      #f38d70

# Popup selection background, search background
set $waveBlue2      #f38d70

# Diff Add (background)
set $winterGreen    #adda78

# Diff Change (background)
set $winterYellow   #f9cc6c

# Diff Deleted (background)
set $winterRed      #fd6883

# Diff Line (background)
set $winterBlue     #f38d70

# Git Add
set $autumnGreen    #adda78

# Git Delete
set $autumnRed      #fd6883

# Git Change
set $autumnYellow   #f9cc6c

# Diagnostic Error
set $samuraiRed     #fd6883

# Diagnostic Warning
set $roninYellow    #f9cc6c

# Diagnostic Info
set $waveAqua1      #f38d70

# Diagnostic Hint
set $dragonBlue     #f38d70

# Comments
set $fujiGray       #948a8b

# Light foreground
set $springViolet1  #e6d9db

# Statements and Keywords
set $oniViolet      #a8a9eb

# Functions and Titles
set $crystalBlue    #f38d70

# Brackets and punctuation
set $springViolet2  #a8a9eb

# Specials and builtin functions
set $springBlue     #f38d70

# Not used (assigned Nightfox-consistent shades)
set $lightBlue      #85dacc
set $boatYellow1    #f9cc6c

# Types
set $waveAqua2      #85dacc

# Strings
set $springGreen    #adda78

# Operators, RegEx
set $boatYellow2    #f9cc6c

# Identifiers
set $carpYellow     #f9cc6c

# Numbers
set $sakuraPink     #a8a9eb

# Standout specials 1 (builtin variables)
set $waveRed        #fd6883

# Standout specials 2 (exception handling, return)
set $peachRed       #fd6883

# Constants, imports, booleans
set $surimiOrange   

# Deprecated
set $katanaGray     #948a8b
