# Global properties
separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#e6d9db

[separator]
full_text="⟨"
color=#72696a

[bandwidth]
command=bandwith
interval=1
label=   
color=#c8e292

[separator]
full_text="⟨"
color=#72696a

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#fd6883

[separator]
full_text="⟨"
color=#72696a

[memory]
label=  
command=memory
interval=2
color=#fd6883

[separator]
full_text="⟨"
color=#72696a

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#fd6883

[separator]
full_text="⟨"
color=#72696a

[wifi]
command=wifi-status
interval=30
color=#e6d9db

[separator]
full_text="⟨"
color=#72696a

[volume]
command=wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{if ($3 == "[MUTED]") print "MUTED"; else print int($2 * 100) " %"}'
interval=1
label=   
color=#fcd675

[separator]
full_text="⟨"
color=#72696a

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#e6d9db

[separator]
full_text="⟨"
color=#72696a

[brightness]
command=brightnessctl g | awk '{print $1}'
interval=5
label=   
color=#e6d9db

[separator]
full_text="⟨"
color=#72696a

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#fd6883

[separator]
full_text="⟨"
color=#72696a

[keymap]
command=kb-layout
interval=2
color=#fd6883

[separator]
full_text="⟨"
color=#72696a

[battery]
command=battery
interval=30
color=#c8e292

[separator]
full_text="⟨"
color=#72696a

[shutdown_menu]
full_text=
command=powermenu
color=#fd6883
