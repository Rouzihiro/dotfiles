#!/usr/bin/env python3
"""
Generate a semantic theme.toml from a Kitty config file.
Usage: python kitty_to_theme.py /path/to/kitty.conf
"""

import re
import sys
from pathlib import Path
from typing import Dict, Optional

# ----------------------------------------------------------------------
# Color helpers
# ----------------------------------------------------------------------
def hex_to_rgb(hex_color: str) -> tuple:
    """Convert #rrggbb to (r, g, b) integers 0-255."""
    hex_color = hex_color.lstrip('#')
    return tuple(int(hex_color[i:i+2], 16) for i in (0, 2, 4))

def luminance(rgb: tuple) -> float:
    """Relative luminance (0-1) per WCAG."""
    r, g, b = [x / 255.0 for x in rgb]
    for c in (r, g, b):
        if c <= 0.03928:
            c = c / 12.92
        else:
            c = ((c + 0.055) / 1.055) ** 2.4
    return 0.2126 * r + 0.7152 * g + 0.0722 * b

def get_contrast_color(hex_color: str, dark_color: str = "#090c0c", light_color: str = "#d7ccc8") -> str:
    """Return dark_color if background is light, else light_color."""
    rgb = hex_to_rgb(hex_color)
    lum = luminance(rgb)
    # Use dark text on light backgrounds, light text on dark backgrounds
    return dark_color if lum > 0.5 else light_color

def blend_colors(c1: str, c2: str, ratio: float = 0.5) -> str:
    """Blend two hex colors."""
    r1, g1, b1 = hex_to_rgb(c1)
    r2, g2, b2 = hex_to_rgb(c2)
    r = int(r1 * (1 - ratio) + r2 * ratio)
    g = int(g1 * (1 - ratio) + g2 * ratio)
    b = int(b1 * (1 - ratio) + b2 * ratio)
    return f"#{r:02x}{g:02x}{b:02x}"

# ----------------------------------------------------------------------
# Parse kitty.conf
# ----------------------------------------------------------------------
def parse_kitty_conf(path: Path) -> Dict[str, str]:
    """Extract color definitions from kitty.conf."""
    colors = {}
    with open(path, 'r') as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith('#'):
                continue
            # Match "key value" or "key=value"
            match = re.match(r'^(\w+)\s+([#\w]+)$', line)
            if not match:
                match = re.match(r'^(\w+)\s*=\s*([#\w]+)$', line)
            if match:
                key, value = match.groups()
                if key.startswith('color') or key in ('background', 'foreground', 'cursor', 'selection_background', 'selection_foreground'):
                    colors[key] = value
    return colors

# ----------------------------------------------------------------------
# Build semantic palette
# ----------------------------------------------------------------------
def build_palette(kitty_colors: Dict[str, str]) -> Dict[str, str]:
    """
    Convert Kitty colors to a named palette:
    - bg_dark      : main background
    - bg_medium    : secondary background (often color6)
    - bg_light     : tertiary background (often color5)
    - fg           : main foreground
    - accent       : highlight color (color1 or color4)
    - border       : borders (color5 or blended)
    - success      : success messages (usually fg)
    - error        : error messages (accent)
    - fg_inverse   : text that sits on accent backgrounds
    """
    # Default fallbacks (dark theme)
    bg_dark = kitty_colors.get('background', '#1e1e1e')
    fg = kitty_colors.get('foreground', '#dcdcdc')
    
    # Get ANSI colors (0-15)
    ansi = {i: kitty_colors.get(f'color{i}', None) for i in range(16)}
    
    # Determine accent: prefer color1 (red family) or color4 (blue family)
    accent = ansi.get(1) or ansi.get(4) or fg
    # Medium background: usually color6 (cyan) or color2 (green) – but in example it's color6
    bg_medium = ansi.get(6) or ansi.get(2) or blend_colors(bg_dark, fg, 0.3)
    # Light background / borders: color5 (magenta) or color3 (yellow)
    bg_light = ansi.get(5) or ansi.get(3) or blend_colors(bg_dark, fg, 0.6)
    
    # Border: use bg_light if available, else blend
    border = bg_light
    
    # Success: often color2 (green) or fallback to fg
    success = ansi.get(2) or fg
    # Error: same as accent (or color1)
    error = accent
    
    # Inverse text for accent backgrounds
    fg_inverse = get_contrast_color(accent, dark_color="#090c0c", light_color=fg)
    
    return {
        'bg_dark': bg_dark,
        'bg_medium': bg_medium,
        'bg_light': bg_light,
        'fg': fg,
        'fg_inverse': fg_inverse,
        'accent': accent,
        'border': border,
        'success': success,
        'error': error,
        # Extra for Kitty section
        'cursor': kitty_colors.get('cursor', accent),
        'selection_bg': kitty_colors.get('selection_background', accent),
        'selection_fg': kitty_colors.get('selection_foreground', fg),
    }

# ----------------------------------------------------------------------
# Generate theme.toml
# ----------------------------------------------------------------------
def generate_toml(palette: Dict[str, str], kitty_colors: Dict[str, str]) -> str:
    """Create the TOML string following the example structure."""
    # Unpack palette
    bg = palette['bg_dark']
    bg2 = palette['bg_medium']
    bg3 = palette['bg_light']
    fg = palette['fg']
    fg_inv = palette['fg_inverse']
    accent = palette['accent']
    border = palette['border']
    success = palette['success']
    error = palette['error']
    cursor = palette['cursor']
    sel_bg = palette['selection_bg']
    sel_fg = palette['selection_fg']
    
    # Kitty ANSI colors (reconstruct from palette)
    # For consistency, we map as in the example:
    # color0/8 = bg, color1/9 = accent, color2/10 = fg, color3/11 = fg,
    # color4/12 = accent, color5/13 = bg3, color6/14 = bg2, color7/15 = fg
    ansi_map = {
        0: bg, 8: bg,
        1: accent, 9: accent,
        2: fg, 10: fg,
        3: fg, 11: fg,
        4: accent, 12: accent,
        5: bg3, 13: bg3,
        6: bg2, 14: bg2,
        7: fg, 15: fg,
    }
    
    toml = f"""[starship]
os_bg = "{bg3}"
os_fg = "{fg_inv}"
dir_bg = "{bg2}"
dir_fg = "{fg}"
git_branch_bg = "{bg3}"
git_branch_fg = "{bg2}"
git_status_bg = "{bg3}"
git_status_fg = "{bg2}"
langs_bg = "{bg2}"
langs_fg = "{fg}"
time_bg = "{bg}"
time_fg = "{fg}"
success = "{success}"
error = "{error}"

[tmux]
pane_border = "{bg2}"
pane_active_border = "{accent}"
message_bg = "{accent}"
message_fg = "{fg_inv}"
git_bg = "{bg3}"
git_fg = "{fg}"
host_bg = "{bg2}"
host_fg = "{fg}"
time_bg = "{bg}"
time_fg = "{fg}"

[hyprland]
active_border = "{accent}"
inactive_border = "{bg3}"

[mako]
bg = "{bg}"
text = "{fg}"
border = "{bg3}"
progress = "{accent}"

[kitty]
bg = "{bg}"
fg = "{fg}"
cursor = "{cursor}"
selection_bg = "{sel_bg}"
selection_fg = "{sel_fg}"
"""
    # Add color0..color15
    for i in range(16):
        toml += f"color{i} = \"{ansi_map[i]}\"\n"
    
    toml += f"""
[wofi]
bg = "{bg}"
border = "{accent}"
input_bg = "{bg2}"
input_border = "{bg3}"
text = "{fg}"
selected_bg = "{fg}"
selected_text = "{bg}"

[nvim]
colorscheme = "generated"
bg = "{bg}"
fg = "{fg}"
accent = "{accent}"
muted = "{bg2}"
border = "{bg3}"
cursorline = "{bg}"

[dircolors]
dir = "{fg}"
link = "{accent}"
archive = "{bg2}"
media = "{fg}"
source = "{fg}"
exec = "{accent}"
ignored = "{bg2}"
bg = "{bg}"
fg = "{fg}"
orphan = "{accent}"
"""
    return toml

# ----------------------------------------------------------------------
# Main
# ----------------------------------------------------------------------
def main():
    if len(sys.argv) != 2:
        print("Usage: python kitty_to_theme.py /path/to/kitty.conf")
        sys.exit(1)
    
    kitty_conf_path = Path(sys.argv[1])
    if not kitty_conf_path.exists():
        print(f"Error: {kitty_conf_path} not found.")
        sys.exit(1)
    
    # Parse Kitty config
    kitty_colors = parse_kitty_conf(kitty_conf_path)
    if not kitty_colors:
        print("Error: No color definitions found in kitty.conf.")
        sys.exit(1)
    
    # Build semantic palette
    palette = build_palette(kitty_colors)
    
    # Generate TOML
    toml_content = generate_toml(palette, kitty_colors)
    
    # Write output next to kitty.conf
    output_path = kitty_conf_path.parent / "theme.toml"
    with open(output_path, 'w') as f:
        f.write(toml_content)
    
    print(f"Theme written to {output_path}")

if __name__ == "__main__":
    main()
