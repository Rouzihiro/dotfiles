# Generated from kitty.conf

# Default foreground
set $fujiWhite      #d9d9d9

# Dark foreground (statuslines)
set $oldWhite       #c4c5b5

# Dark background (statuslines and floating windows)
set $sumiInk0       #1a1a1a

# Default background
set $sumiInk1       #0c0c0c

# Lighter background (colorcolumn, folds)
set $sumiInk2       #625e4c

# Lighter background (cursorline)
set $sumiInk3       #625e4c

# Darker foreground (line numbers, fold column, non-text characters), float borders
set $sumiInk4       #625e4c

# Popup background, visual selection background
set $waveBlue1      #9d65ff

# Popup selection background, search background
set $waveBlue2      #9d65ff

# Diff Add (background)
set $winterGreen    #98e024

# Diff Change (background)
set $winterYellow   #fd971f

# Diff Deleted (background)
set $winterRed      #f4005f

# Diff Line (background)
set $winterBlue     #9d65ff

# Git Add
set $autumnGreen    #98e024

# Git Delete
set $autumnRed      #f4005f

# Git Change
set $autumnYellow   #fd971f

# Diagnostic Error
set $samuraiRed     #f4005f

# Diagnostic Warning
set $roninYellow    #fd971f

# Diagnostic Info
set $waveAqua1      #9d65ff

# Diagnostic Hint
set $dragonBlue     #9d65ff

# Comments
set $fujiGray       #625e4c

# Light foreground
set $springViolet1  #c4c5b5

# Statements and Keywords
set $oniViolet      #f4005f

# Functions and Titles
set $crystalBlue    #9d65ff

# Brackets and punctuation
set $springViolet2  #f4005f

# Specials and builtin functions
set $springBlue     #9d65ff

# Not used (assigned Nightfox-consistent shades)
set $lightBlue      #58d1eb
set $boatYellow1    #fd971f

# Types
set $waveAqua2      #58d1eb

# Strings
set $springGreen    #98e024

# Operators, RegEx
set $boatYellow2    #fd971f

# Identifiers
set $carpYellow     #fd971f

# Numbers
set $sakuraPink     #f4005f

# Standout specials 1 (builtin variables)
set $waveRed        #f4005f

# Standout specials 2 (exception handling, return)
set $peachRed       #f4005f

# Deprecated
set $katanaGray     #625e4c
