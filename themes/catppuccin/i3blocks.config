# Global properties
separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#CDD6F4

[separator]
full_text="⟨"
color=#43465A

[bandwidth]
command=bandwith
interval=1
label=   
color=#A6E3A1

[separator]
full_text="⟨"
color=#43465A

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#F38BA8

[separator]
full_text="⟨"
color=#43465A

[memory]
label=  
command=memory
interval=2
color=#F38BA8

[separator]
full_text="⟨"
color=#43465A

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#F38BA8

[separator]
full_text="⟨"
color=#43465A

[wifi]
command=wifi-status
interval=30
color=#F9E2AF

[separator]
full_text="⟨"
color=#43465A

[volume]
command=wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{if ($3 == "[MUTED]") print "MUTED"; else print int($2 * 100) " %"}'
interval=1
label=   
color=#F9E2AF

[separator]
full_text="⟨"
color=#43465A

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#F9E2AF

[separator]
full_text="⟨"
color=#43465A

[brightness]
command=brightnessctl g | awk '{print $1}'
interval=5
label=   
color=#F9E2AF

[separator]
full_text="⟨"
color=#43465A

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#F38BA8

[separator]
full_text="⟨"
color=#43465A

[keymap]
command=kb-layout
interval=2
color=#F38BA8

[separator]
full_text="⟨"
color=#43465A

[battery]
command=battery
interval=30
color=#A6E3A1

[separator]
full_text="⟨"
color=#43465A

[shutdown_menu]
full_text=
command=powermenu
color=#F38BA8
