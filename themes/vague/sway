# Generated from kitty.conf

# Default foreground
set $fujiWhite      #cdcdcd

# Dark foreground (statuslines)
set $oldWhite       #cdcdcd

# Dark background (statuslines and floating windows)
set $sumiInk0       #1c1c24

# Default background
set $sumiInk1       #141415

# Lighter background (colorcolumn, folds)
set $sumiInk2       #606079

# Lighter background (cursorline)
set $sumiInk3       #606079

# Darker foreground (line numbers, fold column, non-text characters), float borders
set $sumiInk4       #606079

# Popup background, visual selection background
set $waveBlue1      #6e94b2

# Popup selection background, search background
set $waveBlue2      #6e94b2

# Diff Add (background)
set $winterGreen    #7fa563

# Diff Change (background)
set $winterYellow   #f3be7c

# Diff Deleted (background)
set $winterRed      #d8647e

# Diff Line (background)
set $winterBlue     #6e94b2

# Git Add
set $autumnGreen    #7fa563

# Git Delete
set $autumnRed      #d8647e

# Git Change
set $autumnYellow   #f3be7c

# Diagnostic Error
set $samuraiRed     #d8647e

# Diagnostic Warning
set $roninYellow    #f3be7c

# Diagnostic Info
set $waveAqua1      #6e94b2

# Diagnostic Hint
set $dragonBlue     #6e94b2

# Comments
set $fujiGray       #606079

# Light foreground
set $springViolet1  #cdcdcd

# Statements and Keywords
set $oniViolet      #bb9dbd

# Functions and Titles
set $crystalBlue    #6e94b2

# Brackets and punctuation
set $springViolet2  #bb9dbd

# Specials and builtin functions
set $springBlue     #6e94b2

# Not used (assigned Nightfox-consistent shades)
set $lightBlue      #7e98e8
set $boatYellow1    #f3be7c

# Types
set $waveAqua2      #7e98e8

# Strings
set $springGreen    #7fa563

# Operators, RegEx
set $boatYellow2    #f3be7c

# Identifiers
set $carpYellow     #f3be7c

# Numbers
set $sakuraPink     #bb9dbd

# Standout specials 1 (builtin variables)
