# Global properties
separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#cdcdcd

[separator]
full_text="⟨"
color=#1c1c24

[bandwidth]
command=bandwith
interval=1
label=   
color=#6e94b2

[separator]
full_text="⟨"
color=#1c1c24

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#d8647e

[separator]
full_text="⟨"
color=#1c1c24

[memory]
label=  
command=memory
interval=2
color=#d8647e

[separator]
full_text="⟨"
color=#1c1c24

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#d8647e

[separator]
full_text="⟨"
color=#1c1c24

[wifi]
command=wifi-status
interval=30
color=#cdcdcd

[separator]
full_text="⟨"
color=#1c1c24

[volume]
command=wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{if ($3 == "[MUTED]") print "MUTED"; else print int($2 * 100) " %"}'
interval=1
label=   
color=#f3be7c

[separator]
full_text="⟨"
color=#1c1c24

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#cdcdcd

[separator]
full_text="⟨"
color=#1c1c24

[brightness]
command=brightnessctl g | awk '{print $1}'
interval=5
label=   
color=#cdcdcd

[separator]
full_text="⟨"
color=#1c1c24

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#d8647e

[separator]
full_text="⟨"
color=#1c1c24

[keymap]
command=kb-layout
interval=2
color=#d8647e

[separator]
full_text="⟨"
color=#1c1c24

[battery]
command=battery
interval=30
color=#6e94b2

[separator]
full_text="⟨"
color=#1c1c24

[shutdown_menu]
full_text=
command=powermenu
color=#d8647e
