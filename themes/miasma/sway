# Generated from kitty.conf

# Default foreground
set $fujiWhite      #c2c2b0

# Dark foreground (statuslines)
set $oldWhite       #d7c483

# Dark background (statuslines and floating windows)
set $sumiInk0       #000000

# Default background
set $sumiInk1       #222222

# Lighter background (colorcolumn, folds)
set $sumiInk2       #666666

# Lighter background (cursorline)
set $sumiInk3       #666666

# Darker foreground (line numbers, fold column, non-text characters), float borders
set $sumiInk4       #666666

# Popup background, visual selection background
set $waveBlue1      #78824b

# Popup selection background, search background
set $waveBlue2      #78824b

# Diff Add (background)
set $winterGreen    #5f875f

# Diff Change (background)
set $winterYellow   #b36d43

# Diff Deleted (background)
set $winterRed      #685742

# Diff Line (background)
set $winterBlue     #78824b

# Git Add
set $autumnGreen    #5f875f

# Git Delete
set $autumnRed      #685742

# Git Change
set $autumnYellow   #b36d43

# Diagnostic Error
set $samuraiRed     #685742

# Diagnostic Warning
set $roninYellow    #b36d43

# Diagnostic Info
set $waveAqua1      #78824b

# Diagnostic Hint
set $dragonBlue     #78824b

# Comments
set $fujiGray       #666666

# Light foreground
set $springViolet1  #d7c483

# Statements and Keywords
set $oniViolet      #bb7744

# Functions and Titles
set $crystalBlue    #78824b

# Brackets and punctuation
set $springViolet2  #bb7744

# Specials and builtin functions
set $springBlue     #78824b

# Not used (assigned Nightfox-consistent shades)
set $lightBlue      #c9a554
set $boatYellow1    #b36d43

# Types
set $waveAqua2      #c9a554

# Strings
set $springGreen    #5f875f

# Operators, RegEx
set $boatYellow2    #b36d43

# Identifiers
set $carpYellow     #b36d43

# Numbers
set $sakuraPink     #bb7744

# Standout specials 1 (builtin variables)
set $waveRed        #685742

# Standout specials 2 (exception handling, return)
set $peachRed       #685742

# Deprecated
set $katanaGray     #666666
