# Global properties
separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#ffffff

[separator]
full_text="⟨"
color=#404040

[bandwidth]
command=bandwith
interval=1
label=   
color=#cecece

[separator]
full_text="⟨"
color=#404040

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#ececec

[separator]
full_text="⟨"
color=#404040

[memory]
label=  
command=memory
interval=2
color=#ececec

[separator]
full_text="⟨"
color=#404040

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#a4a4a4

[separator]
full_text="⟨"
color=#404040

[wifi]
command=wifi-status
interval=30
color=#ffffff

[separator]
full_text="⟨"
color=#404040

[volume]
command=wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{if ($3 == "[MUTED]") print "MUTED"; else print int($2 * 100) " %"}'
interval=1
label=   
color=#cecece

[separator]
full_text="⟨"
color=#404040

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#ffffff

[separator]
full_text="⟨"
color=#404040

[brightness]
command=brightnessctl g | awk '{print $1}'
interval=5
label=   
color=#ffffff

[separator]
full_text="⟨"
color=#404040

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#ececec

[separator]
full_text="⟨"
color=#404040

[keymap]
command=kb-layout
interval=2
color=#ececec

[separator]
full_text="⟨"
color=#404040

[battery]
command=battery
interval=30
color=#cecece

[separator]
full_text="⟨"
color=#404040

[shutdown_menu]
full_text=
command=powermenu
color=#a4a4a4
