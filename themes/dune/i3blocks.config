separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#d0c8b6

[separator]
full_text="⟨"
color=#36342e

[bandwidth]
command=bandwith
interval=1
label=   
color=#7fa6a3

[separator]
full_text="⟨"
color=#36342e

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#6f8fa3

[separator]
full_text="⟨"
color=#36342e

[memory]
label=  
command=memory
interval=2
color=#6f8fa3

[separator]
full_text="⟨"
color=#36342e

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#c26a4a

[separator]
full_text="⟨"
color=#36342e

[wifi]
command=wifi-status
interval=30
color=#d0c8b6

[separator]
full_text="⟨"
color=#36342e

[volume]
command=sb-volume
interval=1
color=#c2a46a

[separator]
full_text="⟨"
color=#36342e

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#d0c8b6

[separator]
full_text="⟨"
color=#36342e

[brightness]
command=sb-brightness
interval=5
label=   
color=#d0c8b6

[separator]
full_text="⟨"
color=#36342e

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#6f8fa3

[separator]
full_text="⟨"
color=#36342e

[keymap]
command=kb-layout
interval=2
color=#6f8fa3

[separator]
full_text="⟨"
color=#36342e

[battery]
command=battery
interval=30
color=#7fa6a3

[separator]
full_text="⟨"
color=#36342e

[shutdown_menu]
full_text=
command=powermenu
color=#c26a4a
