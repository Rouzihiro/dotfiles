# Global properties
separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#839496

[separator]
full_text="⟨"
color=#002731

[bandwidth]
command=bandwith
interval=1
label=   
color=#859900

[separator]
full_text="⟨"
color=#002731

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#DC322F

[separator]
full_text="⟨"
color=#002731

[memory]
label=  
command=memory
interval=2
color=#DC322F

[separator]
full_text="⟨"
color=#002731

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#DC322F

[separator]
full_text="⟨"
color=#002731

[wifi]
command=wifi-status
interval=30
color=#839496

[separator]
full_text="⟨"
color=#002731

[volume]
command=sb-volume
interval=1
color=#3C342C

[separator]
full_text="⟨"
color=#002731

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#839496

[separator]
full_text="⟨"
color=#002731

[brightness]
command=sb-brightness
interval=5
label=   
color=#839496

[separator]
full_text="⟨"
color=#002731

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#DC322F

[separator]
full_text="⟨"
color=#002731

[keymap]
command=kb-layout
interval=2
color=#DC322F

[separator]
full_text="⟨"
color=#002731

[battery]
command=battery
interval=30
color=#859900

[separator]
full_text="⟨"
color=#002731

[shutdown_menu]
full_text=
command=powermenu
color=#DC322F
