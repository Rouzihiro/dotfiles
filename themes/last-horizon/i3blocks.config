separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#FAFCFB

[separator]
full_text="⟨"
color=#2f2f2f

[bandwidth]
command=bandwith
interval=1
label=   
color=#a5a0b6

[separator]
full_text="⟨"
color=#2f2f2f

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#b59790

[separator]
full_text="⟨"
color=#2f2f2f

[memory]
label=  
command=memory
interval=2
color=#b59790

[separator]
full_text="⟨"
color=#2f2f2f

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#c38b7b

[separator]
full_text="⟨"
color=#2f2f2f

[wifi]
command=wifi-status
interval=30
color=#FAFCFB

[separator]
full_text="⟨"
color=#2f2f2f

[volume]
command=sb-volume
interval=1
color=#6B5E73

[separator]
full_text="⟨"
color=#2f2f2f

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#FAFCFB

[separator]
full_text="⟨"
color=#2f2f2f

[brightness]
command=sb-brightness
interval=5
label=   
color=#FAFCFB

[separator]
full_text="⟨"
color=#2f2f2f

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#b59790

[separator]
full_text="⟨"
color=#2f2f2f

[keymap]
command=kb-layout
interval=2
color=#b59790

[separator]
full_text="⟨"
color=#2f2f2f

[battery]
command=battery
interval=30
color=#a5a0b6

[separator]
full_text="⟨"
color=#2f2f2f

[shutdown_menu]
full_text=
command=powermenu
color=#c38b7b
