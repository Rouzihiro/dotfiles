# Global properties
separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#FAFCFB

[separator]
full_text="⟨"
color=#0c0b0c

[bandwidth]
command=bandwith
interval=1
label=   
color=#87a9b0

[separator]
full_text="⟨"
color=#0c0b0c

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#cfd3cd

[separator]
full_text="⟨"
color=#0c0b0c

[memory]
label=  
command=memory
interval=2
color=#b59790

[separator]
full_text="⟨"
color=#0c0b0c

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#c38b7b

[separator]
full_text="⟨"
color=#0c0b0c

[wifi]
command=wifi-status
interval=30
color=#cfd3cd

[separator]
full_text="⟨"
color=#0c0b0c

[volume]
command=wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{if ($3 == "[MUTED]") print "MUTED"; else print int($2 * 100) " %"}'
interval=1
label=   
color=#6B5E73

[separator]
full_text="⟨"
color=#0c0b0c

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#87a9b0

[separator]
full_text="⟨"
color=#0c0b0c

[brightness]
command=brightnessctl g | awk '{print $1}'
interval=5
label=   
color=#b59790

[separator]
full_text="⟨"
color=#0c0b0c

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#cfd3cd

[separator]
full_text="⟨"
color=#0c0b0c

[keymap]
command=kb-layout
interval=2
color=#b59790

[separator]
full_text="⟨"
color=#0c0b0c

[battery]
command=battery
interval=30
color=#87a9b0

[separator]
full_text="⟨"
color=#0c0b0c

[shutdown_menu]
full_text=
command=powermenu
color=#c38b7b
