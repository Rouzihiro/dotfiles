# Generated from kitty.conf

# Default foreground
set $fujiWhite      #FAFCFB

# Dark foreground (statuslines)
set $oldWhite       #cfd3cd

# Dark background (statuslines and floating windows)
set $sumiInk0       #0c0b0c

# Default background
set $sumiInk1       #0c0b0c

# Lighter background (colorcolumn, folds)
set $sumiInk2       #584e51

# Lighter background (cursorline)
set $sumiInk3       #584e51

# Darker foreground (line numbers, fold column, non-text characters), float borders
set $sumiInk4       #584e51

# Popup background, visual selection background
set $waveBlue1      #b59790

# Popup selection background, search background
set $waveBlue2      #b59790

# Diff Add (background)
set $winterGreen    #87a9b0

# Diff Change (background)
set $winterYellow   #6B5E73

# Diff Deleted (background)
set $winterRed      #c38b7b

# Diff Line (background)
set $winterBlue     #b59790

# Git Add
set $autumnGreen    #87a9b0

# Git Delete
set $autumnRed      #c38b7b

# Git Change
set $autumnYellow   #6B5E73

# Diagnostic Error
set $samuraiRed     #c38b7b

# Diagnostic Warning
set $roninYellow    #6B5E73

# Diagnostic Info
set $waveAqua1      #b59790

# Diagnostic Hint
set $dragonBlue     #b59790

# Comments
set $fujiGray       #584e51

# Light foreground
set $springViolet1  #cfd3cd

# Statements and Keywords
