separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#c5c9c5

[separator]
full_text="⟨"
color=#313030

[bandwidth]
command=bandwith
interval=1
label=   
color=#8ea4a2

[separator]
full_text="⟨"
color=#313030

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#8ba4b0

[separator]
full_text="⟨"
color=#313030

[memory]
label=  
command=memory
interval=2
color=#8ba4b0

[separator]
full_text="⟨"
color=#313030

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#c4746e

[separator]
full_text="⟨"
color=#313030

[wifi]
command=wifi-status
interval=30
color=#c5c9c5

[separator]
full_text="⟨"
color=#313030

[volume]
command=sb-volume
interval=1
color=#c4b28a

[separator]
full_text="⟨"
color=#313030

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#c5c9c5

[separator]
full_text="⟨"
color=#313030

[brightness]
command=sb-brightness
interval=5
label=   
color=#c5c9c5

[separator]
full_text="⟨"
color=#313030

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#8ba4b0

[separator]
full_text="⟨"
color=#313030

[keymap]
command=kb-layout
interval=2
color=#8ba4b0

[separator]
full_text="⟨"
color=#313030

[battery]
command=battery
interval=30
color=#8ea4a2

[separator]
full_text="⟨"
color=#313030

[shutdown_menu]
full_text=
command=powermenu
color=#c4746e
