# Global properties
separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#c5c9c5

[separator]
full_text="⟨"
color=#181616

[bandwidth]
command=bandwith
interval=1
label=   
color=#c4b28a

[separator]
full_text="⟨"
color=#181616

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#7FB4CA

[separator]
full_text="⟨"
color=#181616

[memory]
label=  
command=memory
interval=2
color=#7FB4CA

[separator]
full_text="⟨"
color=#181616

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#c4746e

[separator]
full_text="⟨"
color=#181616

[wifi]
command=wifi-status
interval=30
color=#C8C093

[separator]
full_text="⟨"
color=#181616

[volume]
command=wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{if ($3 == "[MUTED]") print "MUTED"; else print int($2 * 100) " %"}'
interval=1
label=   
color=#E6C384

[separator]
full_text="⟨"
color=#181616

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#C8C093

[separator]
full_text="⟨"
color=#181616

[brightness]
command=brightnessctl g | awk '{print $1}'
interval=5
label=   
color=#C8C093

[separator]
full_text="⟨"
color=#181616

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#7FB4CA

[separator]
full_text="⟨"
color=#181616

[keymap]
command=kb-layout
interval=2
color=#7FB4CA

[separator]
full_text="⟨"
color=#181616

[battery]
command=battery
interval=30
color=#c4b28a

[separator]
full_text="⟨"
color=#181616

[shutdown_menu]
full_text=
command=powermenu
color=#c4746e
