# Global properties
separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#575279

[separator]
full_text="⟨"
color=#9893a5

[bandwidth]
command=bandwith
interval=1
label=   
color=#286983

[separator]
full_text="⟨"
color=#9893a5

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#ea9d34

[separator]
full_text="⟨"
color=#9893a5

[memory]
label=  
command=memory
interval=2
color=#b4637a

[separator]
full_text="⟨"
color=#9893a5

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#b4637a

[separator]
full_text="⟨"
color=#9893a5

[wifi]
command=wifi-status
interval=30
color=#ea9d34

[separator]
full_text="⟨"
color=#9893a5

[volume]
command=wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{if ($3 == "[MUTED]") print "MUTED"; else print int($2 * 100) " %"}'
interval=1
label=   
color=#ea9d34

[separator]
full_text="⟨"
color=#9893a5

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#286983

[separator]
full_text="⟨"
color=#9893a5

[brightness]
command=brightnessctl g | awk '{print $1}'
interval=5
label=   
color=#b4637a

[separator]
full_text="⟨"
color=#9893a5

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#ea9d34

[separator]
full_text="⟨"
color=#9893a5

[keymap]
command=kb-layout
interval=2
color=#b4637a

[separator]
full_text="⟨"
color=#9893a5

[battery]
command=battery
interval=30
color=#286983

[separator]
full_text="⟨"
color=#9893a5

[shutdown_menu]
full_text=
command=powermenu
color=#b4637a
