separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#dcd7ba

[separator]
full_text="⟨"
color=#3b3a3d

[bandwidth]
command=bandwith
interval=1
label=   
color=#6a9589

[separator]
full_text="⟨"
color=#3b3a3d

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#7e9cd8

[separator]
full_text="⟨"
color=#3b3a3d

[memory]
label=  
command=memory
interval=2
color=#7e9cd8

[separator]
full_text="⟨"
color=#3b3a3d

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#c34043

[separator]
full_text="⟨"
color=#3b3a3d

[wifi]
command=wifi-status
interval=30
color=#dcd7ba

[separator]
full_text="⟨"
color=#3b3a3d

[volume]
command=sb-volume
interval=1
color=#c0a36e

[separator]
full_text="⟨"
color=#3b3a3d

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#dcd7ba

[separator]
full_text="⟨"
color=#3b3a3d

[brightness]
command=sb-brightness
interval=5
label=   
color=#dcd7ba

[separator]
full_text="⟨"
color=#3b3a3d

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#7e9cd8

[separator]
full_text="⟨"
color=#3b3a3d

[keymap]
command=kb-layout
interval=2
color=#7e9cd8

[separator]
full_text="⟨"
color=#3b3a3d

[battery]
command=battery
interval=30
color=#6a9589

[separator]
full_text="⟨"
color=#3b3a3d

[shutdown_menu]
full_text=
command=powermenu
color=#c34043
