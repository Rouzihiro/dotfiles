# Global properties
separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#00ca7d

[separator]
full_text="⟨"
color=#00060f

[bandwidth]
command=bandwith
interval=1
label=   
color=#029790

[separator]
full_text="⟨"
color=#00060f

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#004cf1

[separator]
full_text="⟨"
color=#00060f

[memory]
label=  
command=memory
interval=2
color=#004cf1

[separator]
full_text="⟨"
color=#00060f

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#c00e0e

[separator]
full_text="⟨"
color=#00060f

[wifi]
command=wifi-status
interval=30
color=#00ca7d

[separator]
full_text="⟨"
color=#00060f

[volume]
command=wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{if ($3 == "[MUTED]") print "MUTED"; else print int($2 * 100) " %"}'
interval=1
label=   
color=#ffdd00

[separator]
full_text="⟨"
color=#00060f

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#00ca7d

[separator]
full_text="⟨"
color=#00060f

[brightness]
command=brightnessctl g | awk '{print $1}'
interval=5
label=   
color=#00ca7d

[separator]
full_text="⟨"
color=#00060f

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#004cf1

[separator]
full_text="⟨"
color=#00060f

[keymap]
command=kb-layout
interval=2
color=#004cf1

[separator]
full_text="⟨"
color=#00060f

[battery]
command=battery
interval=30
color=#029790

[separator]
full_text="⟨"
color=#00060f

[shutdown_menu]
full_text=
command=powermenu
color=#c00e0e
