# : Manager [[[

[mgr]
cwd = { fg = "#00ca7d" }

# Tab
tab_active = { fg = "#2eb8f8", bg = "#0059ff", bold = true }
tab_inactive = { fg = "#00ca7d", bg = "#02adf1" }
tab_width = 1

# Find
find_keyword = { fg = "#c00e0e", bold = true, italic = true, underline = true }
find_position = { fg = "#c00e0e", bold = true, italic = true }

# Marker
marker_copied = { fg = "#c00e0e", bg = "#c00e0e" }
marker_cut = { fg = "#2eb8f8", bg = "#2eb8f8" }
marker_marked = { fg = "#0059ff", bg = "#0059ff" }
marker_selected = { fg = "#33373f", bg = "#33373f" }

# Count
count_copied = { fg = "#00060f", bg = "#2eb8f8" }
count_cut = { fg = "#00060f", bg = "#2eb8f8" }
count_selected = { fg = "#2eb8f8", bg = "#33373f" }

# Border
border_symbol = " "
border_style  = { fg = "#0059ff" }

# : ]]]


# : Status [[[

[status]
separator_open = "🭁"
separator_close = "🭠"
separator_style = { bg = "#02adf1", fg = "#0059ff" }

[mode]
# Mode
normal_main = { bg = "#0059ff", fg = "#2eb8f8", bold = true }
normal_alt  = { bg = "#00060f", fg = "#00ca7d" }

# Select mode
select_main = { bg = "#2eb8f8", fg = "#2eb8f8", bold = true }
select_alt  = { bg = "#00060f", fg = "#00ca7d" }

# Unset mode
unset_main = { bg = "#33373f", fg = "#2eb8f8", bold = true }
unset_alt  = { bg = "#00060f", fg = "#00ca7d" }

# Progress
progress_label = { bold = true }
progress_normal = { fg = "#0059ff", bg = "#00060f" }
progress_error = { fg = "#c00e0e", bg = "#00060f" }

# Permissions
permissions_t = { fg = "#0059ff" }
permissions_w = { fg = "#33373f" }
permissions_x = { fg = "#c00e0e" }
permissions_r = { fg = "#00ca7d" }
permissions_s = { fg = "#2eb8f8" }

# : ]]]


# : Select [[[

[select]
border = { fg = "#0059ff" }
active = { fg = "#33373f", bold = true }

# : ]]]


# : Input [[[

[input]
border = { fg = "#0059ff" }
value = { fg = "#00ca7d" }

# : ]]]

# : Tabs [[[

[tabs]
active = { fg = "#0059ff", bold = true, bg = "#00060f" }
inactive = { fg = "#2eb8f8", bg = "#00060f" }
sep_inner = { open = "[", close = "]" }

# : ]]]


# : Completion [[[

[completion]
border = { fg = "#0059ff", bg = "#02adf1" }

# : ]]]


# : Tasks [[[

[tasks]
border = { fg = "#0059ff" }
title = {}
hovered = { fg = "#2eb8f8", underline = true }

# : ]]]


# : Which [[[

[which]
cols = 3
mask = { bg = "#00060f" }
cand = { fg = "#0059ff" }
rest = { fg = "#2eb8f8" }
desc = { fg = "#00ca7d" }
separator = " ▶ "
separator_style = { fg = "#00ca7d" }

# : ]]]


# : Help [[[

[help]
on = { fg = "#00ca7d" }
run = { fg = "#00ca7d" }
footer = { fg = "#2eb8f8", bg = "#2eb8f8" }

# : ]]]


# : Notify [[[

[notify]
title_info = { fg = "#33373f" }
title_warn = { fg = "#0059ff" }
title_error = { fg = "#c00e0e" }

# : ]]]


# : File-specific styles [[[

[filetype]

rules = [
    # Images
    { mime = "image/*", fg = "#33373f" },

    # Media
    { mime = "{audio,video}/*", fg = "#0059ff" },

    # Archives
    { mime = "application/{zip,rar,7z*,tar,gzip,xz,zstd,bzip*,lzma,compress,archive,cpio,arj,xar,ms-cab*}", fg = "#2eb8f8" },

    # Documents
    { mime = "application/{pdf,doc,rtf}", fg = "#00ca7d" },

    # Special files
    { name = "*", is = "orphan", bg = "#c00e0e" },
    { name = "*", is = "exec", fg = "#2eb8f8" },

    # Fallback
    { name = "*", fg = "#00ca7d" },
    { name = "*/", fg = "#0059ff" },
]

# : ]]]
