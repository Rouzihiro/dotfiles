# Global properties
separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#d6e2ee

[separator]
full_text="⟨"
color=#6fb8e3

[bandwidth]
command=bandwith
interval=1
label=   
color=#5e95bc

[separator]
full_text="⟨"
color=#6fb8e3

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#f2fcff

[separator]
full_text="⟨"
color=#6fb8e3

[memory]
label=  
command=memory
interval=2
color=#f2fcff

[separator]
full_text="⟨"
color=#6fb8e3

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#4d86b0

[separator]
full_text="⟨"
color=#6fb8e3

[wifi]
command=wifi-status
interval=30
color=#d6e2ee

[separator]
full_text="⟨"
color=#6fb8e3

[volume]
command=wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{if ($3 == "[MUTED]") print "MUTED"; else print int($2 * 100) " %"}'
interval=1
label=   
color=#9dcae5

[separator]
full_text="⟨"
color=#6fb8e3

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#d6e2ee

[separator]
full_text="⟨"
color=#6fb8e3

[brightness]
command=brightnessctl g | awk '{print $1}'
interval=5
label=   
color=#d6e2ee

[separator]
full_text="⟨"
color=#6fb8e3

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#f2fcff

[separator]
full_text="⟨"
color=#6fb8e3

[keymap]
command=kb-layout
interval=2
color=#f2fcff

[separator]
full_text="⟨"
color=#6fb8e3

[battery]
command=battery
interval=30
color=#5e95bc

[separator]
full_text="⟨"
color=#6fb8e3

[shutdown_menu]
full_text=
command=powermenu
color=#4d86b0
