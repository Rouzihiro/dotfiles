separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#d6e2ee

[separator]
full_text="⟨"
color=#324049

[bandwidth]
command=bandwith
interval=1
label=   
color=#b4e4f6

[separator]
full_text="⟨"
color=#324049

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#6fb8e3

[separator]
full_text="⟨"
color=#324049

[memory]
label=  
command=memory
interval=2
color=#6fb8e3

[separator]
full_text="⟨"
color=#324049

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#4d86b0

[separator]
full_text="⟨"
color=#324049

[wifi]
command=wifi-status
interval=30
color=#d6e2ee

[separator]
full_text="⟨"
color=#324049

[volume]
command=sb-volume
interval=1
color=#6fa4c9

[separator]
full_text="⟨"
color=#324049

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#d6e2ee

[separator]
full_text="⟨"
color=#324049

[brightness]
command=sb-brightness
interval=5
label=   
color=#d6e2ee

[separator]
full_text="⟨"
color=#324049

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#6fb8e3

[separator]
full_text="⟨"
color=#324049

[keymap]
command=kb-layout
interval=2
color=#6fb8e3

[separator]
full_text="⟨"
color=#324049

[battery]
command=battery
interval=30
color=#b4e4f6

[separator]
full_text="⟨"
color=#324049

[shutdown_menu]
full_text=
command=powermenu
color=#4d86b0
