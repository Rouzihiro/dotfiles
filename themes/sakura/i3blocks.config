separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#f0eaed

[separator]
full_text="⟨"
color=#2f272b

[bandwidth]
command=bandwith
interval=1
label=   
color=#E8C099

[separator]
full_text="⟨"
color=#2f272b

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#D9A56C

[separator]
full_text="⟨"
color=#2f272b

[memory]
label=  
command=memory
interval=2
color=#D9A56C

[separator]
full_text="⟨"
color=#2f272b

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#E85F6F

[separator]
full_text="⟨"
color=#2f272b

[wifi]
command=wifi-status
interval=30
color=#f0eaed

[separator]
full_text="⟨"
color=#2f272b

[volume]
command=sb-volume
interval=1
color=#D4A882

[separator]
full_text="⟨"
color=#2f272b

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#f0eaed

[separator]
full_text="⟨"
color=#2f272b

[brightness]
command=sb-brightness
interval=5
label=   
color=#f0eaed

[separator]
full_text="⟨"
color=#2f272b

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#D9A56C

[separator]
full_text="⟨"
color=#2f272b

[keymap]
command=kb-layout
interval=2
color=#D9A56C

[separator]
full_text="⟨"
color=#2f272b

[battery]
command=battery
interval=30
color=#E8C099

[separator]
full_text="⟨"
color=#2f272b

[shutdown_menu]
full_text=
command=powermenu
color=#E85F6F
