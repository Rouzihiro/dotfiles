# Global properties
separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#f0eaed

[separator]
full_text="⟨"
color=#4a3c45

[bandwidth]
command=bandwith
interval=1
label=   
color=#FF7A8A

[separator]
full_text="⟨"
color=#4a3c45

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#D1B399

[separator]
full_text="⟨"
color=#4a3c45

[memory]
label=  
command=memory
interval=2
color=#D1B399

[separator]
full_text="⟨"
color=#4a3c45

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#E85F6F

[separator]
full_text="⟨"
color=#4a3c45

[wifi]
command=wifi-status
interval=30
color=#f0eaed

[separator]
full_text="⟨"
color=#4a3c45

[volume]
command=wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{if ($3 == "[MUTED]") print "MUTED"; else print int($2 * 100) " %"}'
interval=1
label=   
color=#E6BA94

[separator]
full_text="⟨"
color=#4a3c45

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#f0eaed

[separator]
full_text="⟨"
color=#4a3c45

[brightness]
command=brightnessctl g | awk '{print $1}'
interval=5
label=   
color=#f0eaed

[separator]
full_text="⟨"
color=#4a3c45

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#D1B399

[separator]
full_text="⟨"
color=#4a3c45

[keymap]
command=kb-layout
interval=2
color=#D1B399

[separator]
full_text="⟨"
color=#4a3c45

[battery]
command=battery
interval=30
color=#FF7A8A

[separator]
full_text="⟨"
color=#4a3c45

[shutdown_menu]
full_text=
command=powermenu
color=#E85F6F
