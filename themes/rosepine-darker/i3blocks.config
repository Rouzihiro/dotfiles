# Global properties
separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#e0def4

[separator]
full_text="⟨"
color=#26233a

[bandwidth]
command=bandwith
interval=1
label=   
color=#31748f

[separator]
full_text="⟨"
color=#26233a

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#eb6f92

[separator]
full_text="⟨"
color=#26233a

[memory]
label=  
command=memory
interval=2
color=#eb6f92

[separator]
full_text="⟨"
color=#26233a

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#eb6f92

[separator]
full_text="⟨"
color=#26233a

[wifi]
command=wifi-status
interval=30
color=#e0def4

[separator]
full_text="⟨"
color=#26233a

[volume]
command=sb-volume
interval=1
color=#f6c177

[separator]
full_text="⟨"
color=#26233a

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#e0def4

[separator]
full_text="⟨"
color=#26233a

[brightness]
command=sb-brightness
interval=5
label=   
color=#e0def4

[separator]
full_text="⟨"
color=#26233a

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#eb6f92

[separator]
full_text="⟨"
color=#26233a

[keymap]
command=kb-layout
interval=2
color=#eb6f92

[separator]
full_text="⟨"
color=#26233a

[battery]
command=battery
interval=30
color=#31748f

[separator]
full_text="⟨"
color=#26233a

[shutdown_menu]
full_text=
command=powermenu
color=#eb6f92
