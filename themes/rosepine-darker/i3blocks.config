separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color=#e0def4

[separator]
full_text="⟨"
color=#363443

[bandwidth]
command=bandwith
interval=1
label=   
color=#ebbcba

[separator]
full_text="⟨"
color=#363443

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color=#9ccfd8

[separator]
full_text="⟨"
color=#363443

[memory]
label=  
command=memory
interval=2
color=#9ccfd8

[separator]
full_text="⟨"
color=#363443

[cpu_usage]
label=  
command=cpu-usage
interval=2
color=#eb6f92

[separator]
full_text="⟨"
color=#363443

[wifi]
command=wifi-status
interval=30
color=#e0def4

[separator]
full_text="⟨"
color=#363443

[volume]
command=sb-volume
interval=1
color=#f6c177

[separator]
full_text="⟨"
color=#363443

[power-profile]
command=power-wrapper
interval=5
signal=10
color=#e0def4

[separator]
full_text="⟨"
color=#363443

[brightness]
command=sb-brightness
interval=5
label=   
color=#e0def4

[separator]
full_text="⟨"
color=#363443

[time]
interval=1
command=timer
separator_block_width=10
label=  
color=#9ccfd8

[separator]
full_text="⟨"
color=#363443

[keymap]
command=kb-layout
interval=2
color=#9ccfd8

[separator]
full_text="⟨"
color=#363443

[battery]
command=battery
interval=30
color=#ebbcba

[separator]
full_text="⟨"
color=#363443

[shutdown_menu]
full_text=
command=powermenu
color=#eb6f92
