#!/bin/bash

FILE="$1"
if [ ! -f "$FILE" ]; then
    echo "Not a valid file: $FILE"
    exit 1
fi

choice=$(echo -e "вЖї Rotate 90¬∞\nвЖЇ Rotate -90¬∞\nрЯФД Flip horizontal\nрЯФД Flip vertical\nрЯЦЉпЄП Convert to PNG\nрЯУР Resize 50%\nрЯМИ Grayscale\nвЬВпЄП Crop (interactive)\nрЯТІ Blur\nвЬ® Sharpen\nрЯМЮ Brighten\nрЯМС Darken\nрЯУЭ Watermark\nрЯУП Border\nCancel" | fzf --height=50% --reverse --prompt="Image operation: ")

case "$choice" in
    "вЖї Rotate 90¬∞") magick "$FILE" -rotate 90 "$FILE" ;;
    "вЖЇ Rotate -90¬∞") magick "$FILE" -rotate -90 "$FILE" ;;
    "рЯФД Flip horizontal") magick "$FILE" -flip "$FILE" ;;
    "рЯФД Flip vertical") magick "$FILE" -flop "$FILE" ;;
    "рЯЦЉпЄП Convert to PNG") magick "$FILE" "${FILE%.*}.png" ;;
    "рЯУР Resize 50%") magick "$FILE" -resize 50% "$FILE" ;;
    "рЯМИ Grayscale") magick "$FILE" -colorspace Gray "$FILE" ;;
    "вЬВпЄП Crop (interactive)")
        echo "Enter crop geometry (e.g., 800x600+10+10):"
        echo "Format: WIDTHxHEIGHT+XOFFSET+YOFFSET"
        read -p "Geometry: " geometry
        [ -n "$geometry" ] && magick "$FILE" -crop "$geometry" +repage "$FILE"
        ;;
    "рЯТІ Blur") magick "$FILE" -blur 0x8 "$FILE" ;;
    "вЬ® Sharpen") magick "$FILE" -sharpen 0x1 "$FILE" ;;
    "рЯМЮ Brighten") magick "$FILE" -modulate 110 "$FILE" ;;
    "рЯМС Darken") magick "$FILE" -modulate 90 "$FILE" ;;
    "рЯУЭ Watermark")
        read -p "Enter watermark text: " watermark
        magick "$FILE" -pointsize 36 -fill "rgba(255,255,255,0.5)" -gravity southeast -annotate +10+10 "$watermark" "$FILE"
        ;;
    "рЯУП Border") magick "$FILE" -bordercolor black -border 10x10 "$FILE" ;;
    *) echo "Cancelled" ;;
esac

echo ""
echo "вЬУ Image operation complete!"
sleep 2
