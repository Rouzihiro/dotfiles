#!/bin/bash

set -e

echo "Running fix-mp4..."
fix-mp4

echo "Waiting 2 seconds..."
sleep 2

echo "Files that will be deleted (everything NOT starting with 'fixed_'):"
find . -maxdepth 1 -type f ! -name 'fixed_*' -print

echo
read -p "Do you really want to delete these files? [y/N]: " confirm

if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
  echo "Aborted. No files were deleted."
  exit 0
fi

echo "Deleting files..."
find . -maxdepth 1 -type f ! -name 'fixed_*' -delete

echo "Waiting 2 seconds..."
sleep 2

echo "Renaming fixed_* files..."

shopt -s nullglob
for f in fixed_*; do
  mv -- "$f" "${f#fixed_}"
done

echo "Done."
