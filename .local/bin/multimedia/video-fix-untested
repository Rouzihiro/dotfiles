#!/usr/bin/env bash
# fix_videos.sh — Fast lossless timestamp/container fix for grabbed web clips
# No re-encoding. Uses -c copy + genpts. Typically 10-50x faster than re-encoding.
# Usage: ./fix_videos.sh [directory]   (defaults to current directory)

set -euo pipefail

INPUT_DIR="${1:-.}"
OUTPUT_DIR="${INPUT_DIR}/fixed"
LOG_FILE="${OUTPUT_DIR}/fix_videos.log"

EXTENSIONS=("mp4" "mkv" "webm" "mov" "avi" "ts" "flv" "m4v")

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'

if ! command -v ffmpeg &>/dev/null; then
  echo -e "${RED}Error: ffmpeg not found.${RESET}"
  echo "  macOS:  brew install ffmpeg"
  echo "  Ubuntu: sudo apt install ffmpeg"
  exit 1
fi

mkdir -p "$OUTPUT_DIR"
echo -e "${BOLD}${CYAN}Video Fix — fast lossless remux + timestamp repair${RESET}"
echo -e "Input dir : ${INPUT_DIR}"
echo -e "Output dir: ${OUTPUT_DIR}"
echo ""

FILES=()
for ext in "${EXTENSIONS[@]}"; do
  while IFS= read -r -d '' f; do
    [[ "$f" == "$OUTPUT_DIR"* ]] && continue
    FILES+=("$f")
  done < <(find "$INPUT_DIR" -maxdepth 1 -iname "*.${ext}" -print0 2>/dev/null)
done

if [[ ${#FILES[@]} -eq 0 ]]; then
  echo -e "${YELLOW}No video files found in: ${INPUT_DIR}${RESET}"
  exit 0
fi

echo -e "Found ${BOLD}${#FILES[@]}${RESET} file(s) to process."
printf '%.0s─' {1..60}; echo ""

PASS=0; FAIL=0; SKIP=0

for INPUT in "${FILES[@]}"; do
  BASENAME=$(basename "$INPUT")
  NAME="${BASENAME%.*}"
  OUTPUT="${OUTPUT_DIR}/${NAME}_fixed.mp4"

  echo -e "\n${BOLD}▶ ${BASENAME}${RESET}"

  if [[ -f "$OUTPUT" ]]; then
    echo -e "  ${YELLOW}⚠ Already exists — skipping.${RESET}"
    ((SKIP++)); continue
  fi

  START=$(date +%s%3N)

  # -fflags +genpts     : regenerate broken/missing presentation timestamps
  # -avoid_negative_ts make_zero : shift timestamps so none are negative
  # -c copy             : stream copy — zero re-encoding, lossless, very fast
  # -movflags +faststart: move MOOV atom to front for instant TV/DLNA playback
  # -map 0              : keep all streams (video, audio, subtitles)
  if ffmpeg -y \
      -fflags +genpts \
      -i "$INPUT" \
      -avoid_negative_ts make_zero \
      -c copy \
      -movflags +faststart \
      -map 0 \
      "$OUTPUT" \
      >> "$LOG_FILE" 2>&1; then

    END=$(date +%s%3N)
    ELAPSED=$(( (END - START) ))
    SIZE_IN=$(du -sh "$INPUT" | cut -f1)
    SIZE_OUT=$(du -sh "$OUTPUT" | cut -f1)
    echo -e "  ${GREEN}✔ Done in ${ELAPSED}ms${RESET}  (${SIZE_IN} → ${SIZE_OUT})"
    ((PASS++))
  else
    echo -e "  ${RED}✘ Failed — see: ${LOG_FILE}${RESET}"
    rm -f "$OUTPUT"
    ((FAIL++))
  fi
done

printf '%.0s─' {1..60}; echo ""
echo -e "${BOLD}Summary${RESET}  ✔ ${PASS}  $([ $SKIP -gt 0 ] && echo "⚠ skipped ${SKIP}  ")$([ $FAIL -gt 0 ] && echo "✘ failed ${FAIL}")"
[[ $PASS -gt 0 ]] && echo -e "Fixed files: ${BOLD}${OUTPUT_DIR}${RESET}"
