#!/bin/bash

# Define available targets (including COMPLETE and DELETE_BACKUPS)
TARGETS=(
    "COMPLETE"
    "DELETE_BACKUPS"
    "alacritty"
    "bar.py"
    "broot"
    "btop"
    "dircolors"
    "eza"
    "foot"
    "hyprland"
    "i3blocks"
    "lazygit"
    "mako"
    "rofi"
    "sway"
    "tmuxrofi"
    "waybar"
    "yazi"
)

THEMES_DIR=~/dotfiles/themes

# Check if themes directory exists
if [ ! -d "$THEMES_DIR" ]; then
    echo "Error: Themes directory not found: $THEMES_DIR"
    exit 1
fi

# Function to generate themes for a specific target
# Usage: generate_target <target> [theme1 theme2 ...]
# If no themes provided, runs against all themes
generate_target() {
    local target="$1"
    shift
    local theme_filter=("$@")

    if [ ${#theme_filter[@]} -gt 0 ]; then
        echo "Generating themes for target: $target (themes: ${theme_filter[*]})"
    else
        echo "Generating themes for target: $target (all themes)"
    fi
    echo "================================"

    cd "$THEMES_DIR" || return 1

    for theme in */; do
        theme_name="${theme%/}"

        # If a filter is set, skip themes not in it
        if [ ${#theme_filter[@]} -gt 0 ]; then
            local match=0
            for f in "${theme_filter[@]}"; do
                [ "$f" = "$theme_name" ] && match=1 && break
            done
            [ $match -eq 0 ] && continue
        fi

        echo "Processing: $theme_name"

        if cd "$theme_name" 2>/dev/null; then
            python ~/Projects/theme-generator/main.py "$target"
            cd ..
        else
            echo "  Failed to enter $theme_name"
        fi
    done

    echo "================================"
    echo "Done: $target"
    echo ""
}

# Function to delete backup files
delete_backups() {
    echo "Deleting backup files from $THEMES_DIR"
    echo "================================"

    local count_before
    count_before=$(find "$THEMES_DIR" -type f \( -name "*.*.backup" -o -name "*.backup.*" -o -name "*.backup" \) 2>/dev/null | wc -l)

    if [ "$count_before" -eq 0 ]; then
        echo "No backup files found."
        return
    fi

    echo "Found $count_before backup files to delete:"
    find "$THEMES_DIR" -type f \( -name "*.*.backup" -o -name "*.backup.*" -o -name "*.backup" \) -exec ls -la {} \; 2>/dev/null
    echo ""

    find "$THEMES_DIR" -type f -name "*.*.backup" -delete 2>/dev/null
    find "$THEMES_DIR" -type f -name "*.backup.*" -delete 2>/dev/null
    find "$THEMES_DIR" -type f -name "*.backup" -delete 2>/dev/null

    local count_after
    count_after=$(find "$THEMES_DIR" -type f \( -name "*.*.backup" -o -name "*.backup.*" -o -name "*.backup" \) 2>/dev/null | wc -l)
    local deleted=$(( count_before - count_after ))

    echo "================================"
    echo "Deleted $deleted backup files."
}

# Helper: fzf-select which themes to run against
# Sets the global `selected_themes` array
select_themes() {
    local available_themes
    mapfile -t available_themes < <(ls -d "$THEMES_DIR"/*/ 2>/dev/null | xargs -n1 basename | sort)

    if [ ${#available_themes[@]} -eq 0 ]; then
        echo "No themes found in $THEMES_DIR"
        selected_themes=()
        return
    fi

    local theme_scope
   theme_scope=$({ echo "ALL"; printf "%s\n" "${available_themes[@]}"; } \
    | fzf --multi \
          --prompt="Which themes? (ALL or Tab to pick): " \
          --height=20 \
          --header="ALL = run against every theme")

    if [ -z "$theme_scope" ]; then
        echo "No themes selected. Exiting."
        exit 0
    fi

    if echo "$theme_scope" | grep -q "^ALL$"; then
        selected_themes=()  # empty = all themes
    else
        mapfile -t selected_themes <<< "$theme_scope"
    fi
}

# Main logic
if [ -z "$1" ]; then
    # ── Interactive mode ────────────────────────────────────────────────────────

    echo "Select targets to generate (Tab to select multiple, Enter to confirm):"
    echo ""

    selected=$(printf "%s\n" "${TARGETS[@]}" \
        | fzf --multi \
              --prompt="Select targets: " \
              --height=20)

    if [ -z "$selected" ]; then
        echo "No targets selected. Exiting."
        exit 0
    fi

    # Ask which themes to scope to (skip for DELETE_BACKUPS / COMPLETE-only runs)
    needs_theme_select=0
    while IFS= read -r t; do
        [ "$t" != "DELETE_BACKUPS" ] && needs_theme_select=1
    done <<< "$selected"

    selected_themes=()
    if [ $needs_theme_select -eq 1 ]; then
        echo ""
        select_themes
        if [ ${#selected_themes[@]} -gt 0 ]; then
            echo "Running against themes: ${selected_themes[*]}"
        else
            echo "Running against ALL themes"
        fi
        echo ""
    fi

    # Handle COMPLETE
    if echo "$selected" | grep -q "^COMPLETE$"; then
        echo "'COMPLETE' selected - generating EVERYTHING!"
        echo ""
        for target in "${TARGETS[@]}"; do
            if [ "$target" != "COMPLETE" ] && [ "$target" != "DELETE_BACKUPS" ]; then
                generate_target "$target" "${selected_themes[@]}"
            fi
        done
    fi

    # Handle DELETE_BACKUPS
    if echo "$selected" | grep -q "^DELETE_BACKUPS$"; then
        delete_backups
        echo ""
    fi

    # Handle individual targets
    while IFS= read -r target; do
        if [ -n "$target" ] && [ "$target" != "COMPLETE" ] && [ "$target" != "DELETE_BACKUPS" ]; then
            generate_target "$target" "${selected_themes[@]}"
        fi
    done <<< "$selected"

else
    # ── CLI mode ────────────────────────────────────────────────────────────────
    # Usage: script.sh <TARGET> [theme1 theme2 ...]

    target_arg="$1"
    shift
    cli_themes=("$@")  # optional: specific themes passed as extra args

    if [ "$target_arg" = "COMPLETE" ]; then
        echo "Generating ALL targets${cli_themes[*]:+ for themes: ${cli_themes[*]}}..."
        echo ""
        for target in "${TARGETS[@]}"; do
            if [ "$target" != "COMPLETE" ] && [ "$target" != "DELETE_BACKUPS" ]; then
                generate_target "$target" "${cli_themes[@]}"
            fi
        done
        echo "All targets generated!"
        exit 0
    fi

    if [ "$target_arg" = "DELETE_BACKUPS" ]; then
        delete_backups
        exit 0
    fi

    # Validate target
    valid=0
    for target in "${TARGETS[@]}"; do
        if [ "$target_arg" = "$target" ]; then
            valid=1
            break
        fi
    done

    if [ $valid -eq 1 ]; then
        generate_target "$target_arg" "${cli_themes[@]}"
    else
        echo "Error: Invalid target '$target_arg'"
        echo ""
        echo "Usage: $(basename "$0") [TARGET] [theme1 theme2 ...]"
        echo ""
        echo "Valid targets:"
        printf "  %s\n" "${TARGETS[@]}"
        echo ""
        echo "Examples:"
        echo "  $(basename "$0")                      # interactive fzf"
        echo "  $(basename "$0") sway                 # sway, all themes"
        echo "  $(basename "$0") sway nord             # sway, nord only"
        echo "  $(basename "$0") sway nord catppuccin  # sway, two themes"
        echo "  $(basename "$0") COMPLETE nord         # all targets, nord only"
        exit 1
    fi
fi
