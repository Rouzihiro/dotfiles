#!/usr/bin/env bash
set -uo pipefail   # no -e: interactive commands (rm -i) may return non-zero intentionally

PICK_MODE="${PICK_MODE:-0}"
ROOT="${1:-$PWD}"

command -v fzf            >/dev/null || { echo "fzf not found";           exit 1; }
command -v fzf-preview.sh >/dev/null || { echo "fzf-preview.sh not found"; exit 1; }
command -v rg             >/dev/null || { echo "rg not found";            exit 1; }

CACHE_DIR="/tmp/fzf-fm-cache"
mkdir -p "$CACHE_DIR"

STATE_FILE="$CACHE_DIR/current_dir"
MODE_FILE="$CACHE_DIR/mode"        # "tree" | "rg"
FZF_EXIT_FILE="$CACHE_DIR/fzf_exit"

HIDDEN_FILE="$CACHE_DIR/show_hidden"   # "0" | "1"

echo "$ROOT"  > "$STATE_FILE"
echo "tree"   > "$MODE_FILE"
echo "0"      > "$FZF_EXIT_FILE"
echo "0"      > "$HIDDEN_FILE"

# ───────────────────────────────────────────────
# directory listing (cached, ignores noise)
# ───────────────────────────────────────────────
list_dir() {
  local dir="$1"
  local hidden; hidden="$(cat "$HIDDEN_FILE")"
  local cache="$CACHE_DIR/$(printf '%s:%s' "$dir" "$hidden" | md5sum | cut -d' ' -f1)"
  if [[ ! -f "$cache" ]]; then
    if [[ "$hidden" == "1" ]]; then
      find "$dir" \
        -path '*/.git/*'         -prune -o \
        -path '*/node_modules/*' -prune -o \
        -print 2>/dev/null > "$cache"
    else
      find "$dir" \
        -path '*/.git/*'         -prune -o \
        -path '*/node_modules/*' -prune -o \
        -name '.*'               -prune -o \
        -print 2>/dev/null > "$cache"
    fi
  fi
  cat "$cache"
}

bust_cache() { rm -f "$CACHE_DIR/$(printf '%s' "$1" | md5sum | cut -d' ' -f1)"; }

# ───────────────────────────────────────────────
# main loop
# ───────────────────────────────────────────────
while true; do
  CURRENT_DIR="$(cat "$STATE_FILE")"
  MODE="$(cat "$MODE_FILE")"
  HIDDEN="$(cat "$HIDDEN_FILE")"

  # Shared binds array (navigation + bookmarks + mode toggle)
  # Each bind writes state and aborts; the loop re-enters fzf with new state.
  # fzf's exit code is written to FZF_EXIT_FILE from inside the process
  # substitution because mapfile always returns 0 and swallows it otherwise.
  BINDS=(
    --bind "esc:abort"
    --bind "ctrl-b:execute-silent(
               d=\$(cat \"$STATE_FILE\")
               echo \"\$(dirname \"\$d\")\" > \"$STATE_FILE\"
               echo tree > \"$MODE_FILE\"
             )+abort"
    --bind "ctrl-h:execute-silent(echo \"$HOME\"            > \"$STATE_FILE\"; echo tree > \"$MODE_FILE\")+abort"
    --bind "ctrl-d:execute-silent(echo \"$HOME/Downloads\"  > \"$STATE_FILE\"; echo tree > \"$MODE_FILE\")+abort"
    --bind "ctrl-x:execute-silent(echo \"$HOME/Pictures\"   > \"$STATE_FILE\"; echo tree > \"$MODE_FILE\")+abort"
    --bind "ctrl-v:execute-silent(echo \"$HOME/Videos\"     > \"$STATE_FILE\"; echo tree > \"$MODE_FILE\")+abort"
    --bind "ctrl-e:execute-silent(echo \"$HOME/Projects\"   > \"$STATE_FILE\"; echo tree > \"$MODE_FILE\")+abort"
    --bind "ctrl-s:execute-silent(echo \"$HOME/.local/bin\" > \"$STATE_FILE\"; echo tree > \"$MODE_FILE\")+abort"
    --bind "ctrl-g:execute-silent(echo \"$HOME/dotfiles\"   > \"$STATE_FILE\"; echo tree > \"$MODE_FILE\")+abort"
    --bind "ctrl-f:execute-silent(
               if [[ \"\$(cat \"$MODE_FILE\")\" == tree ]]; then
                 echo rg   > \"$MODE_FILE\"
               else
                 echo tree > \"$MODE_FILE\"
               fi
             )+abort"
    --bind "ctrl-]:execute-silent(
               if [[ \"\$(cat \"$HIDDEN_FILE\")\" == 0 ]]; then
                 echo 1 > \"$HIDDEN_FILE\"
               else
                 echo 0 > \"$HIDDEN_FILE\"
               fi
             )+abort"
    --bind "ctrl-r:execute-silent(
               d=\$(cat \"$STATE_FILE\")
               h=\$(cat \"$HIDDEN_FILE\")
               rm -f \"$CACHE_DIR/\$(printf '%s:%s' \"\$d\" \"\$h\" | md5sum | cut -d' ' -f1)\"
             )+abort"
    --bind 'ctrl-p:toggle-preview'
    --bind 'ctrl-/:change-preview-window(hidden|right:60%)'
  )

  FZF_EXIT=0

  if [[ "$MODE" == "rg" ]]; then
    # ── live content search ──────────────────────
    # --disabled: fzf does no fuzzy filtering; rg re-runs on every keystroke.
    # Results are  file:line:col:text  — preview and open strip to filename.
    mapfile -t SELECTED < <(
      fzf \
        --height=100% \
        --layout=reverse \
        --multi \
        --disabled \
        --ansi \
        --prompt="🔍 ${CURRENT_DIR} > " \
        --preview 'f=$(echo {} | cut -d: -f1); fzf-preview.sh "$f"' \
        --preview-window='right:60%,border-left' \
        --bind "change:reload:rg --line-number --color=always --hidden --follow --ignore-case {q} \"$CURRENT_DIR\" 2>/dev/null || true" \
        "${BINDS[@]}"
      echo $? > "$FZF_EXIT_FILE"
    )
  else
    # ── directory tree ───────────────────────────
    mapfile -t SELECTED < <(
      list_dir "$CURRENT_DIR" | fzf \
        --height=100% \
        --layout=reverse \
        --multi \
        --prompt="📁 ${CURRENT_DIR} > " \
        --preview 'fzf-preview.sh "$(readlink -f {} 2>/dev/null || echo {})"' \
        --preview-window='right:60%,border-left' \
        "${BINDS[@]}"
      echo $? > "$FZF_EXIT_FILE"
    )
  fi

  FZF_EXIT="$(cat "$FZF_EXIT_FILE")"

  if [[ $FZF_EXIT -ne 0 ]]; then
    NEW_DIR="$(cat "$STATE_FILE")"
    NEW_MODE="$(cat "$MODE_FILE")"
    NEW_HIDDEN="$(cat "$HIDDEN_FILE")"
    if [[ "$NEW_DIR" != "$CURRENT_DIR" || "$NEW_MODE" != "$MODE" || "$NEW_HIDDEN" != "$HIDDEN" ]]; then
      continue   # state changed (ctrl-b / bookmark / mode toggle / hidden toggle) → loop
    fi
    exit 0       # ESC or ctrl-c with no state change → quit
  fi

  [[ ${#SELECTED[@]} -eq 0 ]] && continue

  # In rg mode entries are  file:line:col:text  — extract just the path
  REAL_FILES=()
  for entry in "${SELECTED[@]}"; do
    if [[ "$MODE" == "rg" ]]; then
      path="$(echo "$entry" | cut -d: -f1)"
    else
      path="$entry"
    fi
    REAL_FILES+=("$(readlink -f "$path" 2>/dev/null || echo "$path")")
  done

  # ── single directory → navigate into it ─────
  if [[ ${#REAL_FILES[@]} -eq 1 && -d "${REAL_FILES[0]}" ]]; then
    echo "${REAL_FILES[0]}" > "$STATE_FILE"
    echo "tree"              > "$MODE_FILE"
    continue
  fi

  # ── pick mode: print to stdout and exit ─────
  if [[ "$PICK_MODE" == "1" ]]; then
    printf '%s\n' "${REAL_FILES[@]}"
    exit 0
  fi

  # ── action menu ─────────────────────────────
  ACTION=$(printf "open\nxdg-open\nmove\ndelete\ncancel" |
    fzf --prompt="action (${#REAL_FILES[@]} file(s)) > ") || continue

  case "$ACTION" in
    open)
      nvim "${REAL_FILES[@]}"
      ;;
    xdg-open)
      for f in "${REAL_FILES[@]}"; do
        xdg-open "$f" >/dev/null 2>&1 & disown
      done
      ;;
    move)
      TARGET=$(find "$HOME" -maxdepth 4 -type d 2>/dev/null |
        fzf --prompt="move destination > ") || continue
      mv "${REAL_FILES[@]}" "$TARGET/"
      bust_cache "$CURRENT_DIR"
      bust_cache "$TARGET"
      ;;
    delete)
      for f in "${REAL_FILES[@]}"; do
        rm -i "$f" </dev/tty || true
      done
      bust_cache "$CURRENT_DIR"
      ;;
    cancel)
      continue
      ;;
  esac
done
