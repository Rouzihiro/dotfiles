#!/usr/bin/env bash
set -euo pipefail

ROOT="${1:-$PWD}"

command -v fzf >/dev/null || exit 1
command -v fzf-preview.sh >/dev/null || exit 1

CACHE_DIR="/tmp/fzf-fm-cache"
mkdir -p "$CACHE_DIR"

STATE_FILE="$CACHE_DIR/current_dir"
echo "$ROOT" > "$STATE_FILE"

# ───────────────────────────────────────────────
# fast cached directory listing
# ───────────────────────────────────────────────
list_dir() {
  local dir="$1"
  local cache="$CACHE_DIR/$(echo "$dir" | md5sum | cut -d' ' -f1)"

  if [[ ! -f "$cache" ]]; then
    find "$dir" \
      -path '*/.git/*' -prune -o \
      -path '*/node_modules/*' -prune -o \
      -print 2>/dev/null > "$cache"
  fi

  cat "$cache"
}

# ───────────────────────────────────────────────
# navigation loop
# ───────────────────────────────────────────────
while true; do
  CURRENT_DIR="$(cat "$STATE_FILE")"

  SELECTED=$(
    list_dir "$CURRENT_DIR" |
    fzf \
      --height=100% \
      --layout=reverse \
      --prompt="📁 ${CURRENT_DIR} > " \
      --preview 'fzf-preview.sh "$(readlink -f {} 2>/dev/null || echo {})"' \
      --preview-window='right:60%,border-left' \
      --bind "esc:execute(
          echo \$(dirname \"$CURRENT_DIR\") > \"$STATE_FILE\"
        )+abort" \
      --bind 'ctrl-/:change-preview-window(hidden|right:60%)'
  ) || exit 0

  [[ -z "$SELECTED" ]] && continue

  # ── resolve symlinks safely ───────────────
  REAL_SELECTED="$(readlink -f "$SELECTED" 2>/dev/null || echo "$SELECTED")"

  # ── enter directory (supports symlinks) ───
  if [[ -d "$REAL_SELECTED" ]]; then
    echo "$REAL_SELECTED" > "$STATE_FILE"
    continue
  fi

  # ── action menu ───────────────────────────
  ACTION=$(printf "open\nxdg-open\nmove\ndelete\ncancel" |
    fzf --prompt="action > ") || continue

  case "$ACTION" in
    open)
      nvim "$REAL_SELECTED"
      ;;

    xdg-open)
      xdg-open "$REAL_SELECTED" >/dev/null 2>&1 & disown
      ;;

    move)
      TARGET=$(fzf-wrapper-path "$HOME") || continue
      mv "$REAL_SELECTED" "$TARGET/"
      ;;

    delete)
      rm -i "$REAL_SELECTED"
      ;;

    cancel)
      continue
      ;;
  esac
done
