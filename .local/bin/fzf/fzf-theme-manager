#!/usr/bin/env bash
# theme-manager — fzf frontend for theme generation

CONFIG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/theme-manager.conf"
DEFAULT_THEMES_DIR="$HOME/dotfiles/themes"
DEFAULT_TEMPLATES_DIR="$HOME/dotfiles/templates"

# ─────────────────────────────
# CONFIG LOAD/SAVE
# ─────────────────────────────
load_config() {
    if [[ -f "$CONFIG_FILE" ]]; then
        source "$CONFIG_FILE"
    fi
    THEMES_DIR="${THEMES_DIR:-$DEFAULT_THEMES_DIR}"
    TEMPLATES_DIR="${TEMPLATES_DIR:-$DEFAULT_TEMPLATES_DIR}"
}

save_config() {
    mkdir -p "$(dirname "$CONFIG_FILE")"
    cat > "$CONFIG_FILE" <<EOF
THEMES_DIR="$THEMES_DIR"
TEMPLATES_DIR="$TEMPLATES_DIR"
EOF
}

# ─────────────────────────────
# GENERATE THEME
# ─────────────────────────────
generate_theme() {
    local theme
    theme=$(find "$THEMES_DIR" -mindepth 1 -maxdepth 1 \( -type d -o -type l \) | sort | \
        xargs -I{} basename {} | \
        fzf --prompt="Select theme > " \
            --header="Generate theme | THEMES: $THEMES_DIR" \
            --preview="ls $THEMES_DIR/{}" \
            --preview-window=right:40%)

    [[ -z "$theme" ]] && return

    local theme_path="$THEMES_DIR/$theme"

    if [[ -f "$theme_path/theme.toml" ]]; then
        echo "→ Running generate-theme-v2.py on $theme..."
        (cd "$theme_path" && generate-theme-v2.py theme.toml)
    elif [[ -f "$theme_path/kitty.conf" ]]; then
        echo "→ No theme.toml found, running kitty_2_theme.py on kitty.conf..."
        (cd "$theme_path" && kitty_2_theme.py kitty.conf)
        if [[ -f "$theme_path/theme.toml" ]]; then
            echo "→ theme.toml generated, running generate-theme-v2.py..."
            (cd "$theme_path" && generate-theme-v2.py theme.toml)
        else
            echo "✗ kitty_2_theme.py did not produce a theme.toml"
            read -rp "Press Enter to continue..."
            return 1
        fi
    else
        echo "✗ Neither theme.toml nor kitty.conf found in $theme_path"
        read -rp "Press Enter to continue..."
        return 1
    fi

    # Update starship palette name to match theme
    local starship_out="$theme_path/starship.toml"
    if [[ -f "$starship_out" ]]; then
        sed -i "s/\[palettes\.zorro\]/[palettes.$theme]/" "$starship_out"
        echo "✓ Starship palette renamed to [palettes.$theme]"
    fi

    echo ""
    read -rp "Done. Press Enter to continue..."
}

# ─────────────────────────────
# SYNC STARSHIP PALETTES
# ─────────────────────────────
sync_starship_palettes() {
    local starship_config="$HOME/.config/starship.toml"

    if [[ ! -f "$starship_config" ]]; then
        echo "✗ $starship_config not found"
        read -rp "Press Enter to continue..."
        return 1
    fi

    local config_only
		config_only=$(sed '/^# ── Palettes/,$d' "$starship_config")

    local palettes=""
    while IFS= read -r -d '' toml; do
        local block
        block=$(sed -n '/^\[palettes\./,$p' "$toml")
        if [[ -n "$block" ]]; then
            palettes+=$'\n'"$block"$'\n'
        fi

		done < <(find "$THEMES_DIR" -mindepth 2 -maxdepth 2 -name "starship.toml" -print0 | sort -z)
			if [[ -z "$palettes" ]]; then
    	echo "✗ No palette blocks found in $THEMES_DIR"
        read -rp "Press Enter to continue..."
        return 1
    fi

    {
        echo "$config_only"
        echo ""
        echo "# ── Palettes (auto-synced by theme-manager) ──"
        echo "$palettes"
    } > "$starship_config"

    local count
    count=$(find "$THEMES_DIR" -mindepth 2 -maxdepth 2 -name "starship.toml" | wc -l)
    echo "✓ Synced $count starship palettes into $starship_config"
    echo ""
    read -rp "Done. Press Enter to continue..."
}

# ─────────────────────────────
# REFRESH THEME LIST
# ─────────────────────────────
refresh_theme_list() {
    local zorro_themes="$HOME/.config/zorro/themes"
    mkdir -p "$zorro_themes"

    local count=0
    for f in "$THEMES_DIR"/*/; do
        ln -nfs "$f" "$zorro_themes/"
        ((count++))
    done

    echo "✓ Linked $count themes from $THEMES_DIR → $zorro_themes"
    sleep 2
}

# ─────────────────────────────
# GENERATE PREVIEWS
# ─────────────────────────────
generate_previews() {
    echo "→ Generating palette previews..."
    z-theme-palettes-gen

    echo "→ Rebuilding thumbnail cache..."
    z-theme-cache

    echo "✓ Previews updated"
    echo ""
    read -rp "Done. Press Enter to continue..."
}

# ─────────────────────────────
# CHANGE THEMES FOLDER
# ─────────────────────────────
change_themes_dir() {
    local new_dir
    new_dir=$(find "$HOME" -mindepth 1 -maxdepth 4 -type d 2>/dev/null | \
        fzf --prompt="Select themes folder > " \
            --header="Current: $THEMES_DIR" \
            --preview="ls {}" \
            --preview-window=right:40%)

    [[ -z "$new_dir" ]] && return

    THEMES_DIR="$new_dir"
    save_config
    echo "✓ Themes dir set to: $THEMES_DIR"
    sleep 1
}

# ─────────────────────────────
# CHANGE TEMPLATES FOLDER
# ─────────────────────────────
change_templates_dir() {
    local new_dir
    new_dir=$(find "$HOME" -mindepth 1 -maxdepth 4 -type d 2>/dev/null | \
        fzf --prompt="Select templates folder > " \
            --header="Current: $TEMPLATES_DIR" \
            --preview="ls {}" \
            --preview-window=right:40%)

    [[ -z "$new_dir" ]] && return

    TEMPLATES_DIR="$new_dir"
    save_config
    echo "✓ Templates dir set to: $TEMPLATES_DIR"
    sleep 1
}

# ─────────────────────────────
# RESET DEFAULTS
# ─────────────────────────────
reset_defaults() {
    THEMES_DIR="$DEFAULT_THEMES_DIR"
    TEMPLATES_DIR="$DEFAULT_TEMPLATES_DIR"
    save_config
    echo "✓ Reset to defaults:"
    echo "  Themes:    $THEMES_DIR"
    echo "  Templates: $TEMPLATES_DIR"
    sleep 2
}

# ─────────────────────────────
# FIRST RUN SETUP
# ─────────────────────────────
first_run_setup() {
    local installer="$HOME/dotfiles/install-themes.sh"

    if [[ ! -f "$installer" ]]; then
        echo "✗ $installer not found"
        read -rp "Press Enter to continue..."
        return 1
    fi

    echo "→ Running install-themes.sh..."
    bash "$installer"

    echo ""
    read -rp "Done. Press Enter to continue..."
}

# ─────────────────────────────
# SET THEME
# ─────────────────────────────
set_theme() {
    if ! command -v rofi-theme-set &>/dev/null; then
        echo "✗ rofi-theme-set not found in PATH"
        read -rp "Press Enter to continue..."
        return 1
    fi
    rofi-theme-set
}

# ─────────────────────────────
# MAIN MENU
# ─────────────────────────────
main_menu() {
    while true; do
        local choice
        choice=$(printf \
            "1) Generate theme\n2) Set theme\n3) Sync starship palettes\n4) Refresh theme list\n5) Generate previews\n6) First run setup\n7) Change themes folder\n8) Change templates folder\n9) Reset to defaults\n10) Quit" | \
            fzf --prompt="Theme Manager > " \
                --header="Themes: $THEMES_DIR | Templates: $TEMPLATES_DIR" \
                --no-preview)

        case "$choice" in
            "1) Generate theme")          generate_theme ;;
            "2) Set theme")               set_theme ;;
 						"3) Refresh theme list")      refresh_theme_list ;;
            "4) Sync starship palettes")  sync_starship_palettes ;;
            "5) Generate previews")       generate_previews ;;
            "6) First run setup")         first_run_setup ;;
            "7) Change themes folder")    change_themes_dir ;;
            "8) Change templates folder") change_templates_dir ;;
            "9) Reset to defaults")       reset_defaults ;;
            "10) Quit"|"")               exit 0 ;;
        esac
    done
}

load_config
main_menu
