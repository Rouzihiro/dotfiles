#!/usr/bin/env bash
set -euo pipefail

TMP_DIR="/tmp/img-toolkit"
mkdir -p "$TMP_DIR"

# ── YOUR EXTERNAL SCRIPTS ─────────────────────────────────────────────────────
SCRIPT1="imgops"                    
CAPTION1="📷  Image Operations"

SCRIPT2="img-converter"             
CAPTION2="🔄  Convert Images"

SCRIPT3="img-uploader"              
CAPTION3="☁️  Upload to Cloud"

# ── helpers ───────────────────────────────────────────────────────────────────
die()  { echo "✗ $*" >&2; exit 1; }
info() { echo "  $*"; }

for cmd in fzf chafa trash numfmt stat magick; do
  command -v "$cmd" &>/dev/null || die "Required tool not found: $cmd"
done

# ── compress function ─────────────────────────────────────────────────────────
compress_image() {
  local path="$1" mode="$2"
  [[ -f "$path" ]] || { info "skipping (gone): $path"; return; }

  local base="${path%.*}"
  local ext="${path##*.}"
  local out="$path"
  
  [[ "$mode" == "new file" ]] && out="${base}-small.${ext}"
  
  local tmp="${TMP_DIR}/$(basename "$base")-tmp.${ext}"
  
  if [[ "$mode" == "smart" ]]; then
    case "$ext" in
      png)
        magick "$path" -resize 2560x1440\> -strip "$tmp"
        command -v oxipng &>/dev/null && oxipng -o 4 --strip all "$tmp" >/dev/null || true
        ;;
      jpg|jpeg)
        magick "$path" -resize 2560x1440\> -strip -quality 85 "$tmp"
        ;;
      webp)
        magick "$path" -resize 2560x1440\> -strip -quality 85 "$tmp"
        ;;
      *)
        magick "$path" -resize 2560x1440\> -strip "$tmp"
        ;;
    esac
  else
    magick "$path" -resize 2560x1440\> -strip "$tmp"
    if [[ "$ext" == "png" ]]; then
      command -v oxipng &>/dev/null && oxipng -o 4 --strip all "$tmp" >/dev/null || true
    fi
  fi
  
  mv "$tmp" "$out"
  
  local before=$(stat -c%s "$path")
  local after=$(stat -c%s "$out")
  local pct=0
  [[ "$before" -gt 0 ]] && pct=$(( (before - after) * 100 / before ))
  info "$(basename "$path")  $(numfmt --to=iec "$before") → $(numfmt --to=iec "$after")  (-${pct}%)"
  
  if [[ "$mode" == "trash original" && "$out" != "$path" ]]; then
    trash "$path"
    info "  (original trashed)"
  fi
}

# ── main browser ──────────────────────────────────────────────────────────────
main() {
  echo ""
  echo "  🖼️  Image Toolkit"
  echo ""
  
  # Show available tools
  echo "  Available tools:"
  
  local script_cmds=()
  local script_captions=()
  
  for i in {1..99}; do
    local caption_var="CAPTION$i"
    local script_var="SCRIPT$i"
    if [[ -n "${!caption_var:-}" ]] && [[ -n "${!script_var:-}" ]]; then
      if command -v "${!script_var}" &>/dev/null; then
        echo "    ✓ ${!caption_var}"
        script_captions+=("${!caption_var}")
        script_cmds+=("${!script_var}")
      else
        echo "    ✗ ${!caption_var} (command '${!script_var}' not found)"
      fi
    fi
  done
  echo "    ✓ Compress images"
  echo ""

  # Select tool
  local tool_choice
  tool_choice=$(printf '%s\n' "${script_captions[@]}" "Compress images" | fzf --prompt="Select tool > " --height=30% --reverse)
  [[ -z "$tool_choice" ]] && exit 0
  
  local RUN_SCRIPT=""
  local COMPRESS_MODE=""
  
  # Check if it's a script
  for i in "${!script_captions[@]}"; do
    if [[ "${script_captions[$i]}" == "$tool_choice" ]]; then
      RUN_SCRIPT="${script_cmds[$i]}"
      break
    fi
  done
  
  # If compress was selected, ask for mode
  if [[ "$tool_choice" == "Compress images" ]]; then
    COMPRESS_MODE=$(printf "smart\noverwrite\nnew file\ntrash original" | fzf --prompt="Compression mode > " --height=25% --reverse)
    [[ -z "$COMPRESS_MODE" ]] && exit 0
  fi
  
  # If running a script, ask for the specific operation FIRST
  local SCRIPT_OPERATION=""
  local EXTRA_ARGS=()
  
  if [[ -n "$RUN_SCRIPT" ]]; then
    echo ""
    # Show the operation menu from imgops script
    SCRIPT_OPERATION=$(printf "↻ Rotate 90°\n↺ Rotate -90°\n🔄 Flip horizontal\n🔄 Flip vertical\n🖼️ Convert to PNG\n📐 Resize 50%%\n🌈 Grayscale\n✂️ Crop (interactive)\n💧 Blur\n✨ Sharpen\n🌞 Brighten\n🌑 Darken\n📝 Watermark\n📏 Border\nCancel" | fzf --height=50% --reverse --prompt="Select operation for all files > ")
    [[ -z "$SCRIPT_OPERATION" ]] || [[ "$SCRIPT_OPERATION" == "Cancel" ]] && exit 0
    
    # For operations that need extra input, ask once here
    case "$SCRIPT_OPERATION" in
      "✂️ Crop (interactive)")
        echo ""
        echo "Enter crop geometry (e.g., 800x600+10+10):"
        echo "Format: WIDTHxHEIGHT+XOFFSET+YOFFSET"
        read -p "Geometry: " geometry
        EXTRA_ARGS=("--crop-geom" "$geometry")
        ;;
      "📝 Watermark")
        echo ""
        read -p "Enter watermark text: " watermark
        EXTRA_ARGS=("--watermark-text" "$watermark")
        ;;
    esac
  fi

  # File collection
  local INPUT
  INPUT=$(fzf --multi --prompt="Select images/folders > " --walker=dir --preview='file {}')
  [[ -z "$INPUT" ]] && exit 0

  local FILES=()
  for t in $INPUT; do
    if [[ -d "$t" ]]; then
      while IFS= read -r f; do
        FILES+=("$f")
      done < <(find "$t" -type f \( -iname "*.png" -o -iname "*.jpg" -o -iname "*.jpeg" -o -iname "*.webp" \))
    else
      FILES+=("$t")
    fi
  done

  # Build table
  local LIST_FILE=$(mktemp)
  for f in "${FILES[@]}"; do
    local bytes=$(stat -c%s "$f")
    local size_h=$(numfmt --to=iec "$bytes")
    local mb=$((bytes / 1024 / 1024))
    
    case "${f##*.}" in
      png) local est=$((mb / 3)) ;;
      jpg|jpeg) local est=$((mb / 2)) ;;
      webp) local est=$((mb / 2)) ;;
      *) local est=$((mb / 2)) ;;
    esac
    
    printf "%s\t%s\tMB:%s→~%s\t%s\n" "$bytes" "$size_h" "$mb" "$est" "$f"
  done | sort -nr > "$LIST_FILE"

  # FZF picker with preview
  local SELECTED
  SELECTED=$(cat "$LIST_FILE" | \
    fzf --multi \
      --delimiter=$'\t' \
      --with-nth=2.. \
      --prompt="Pick images > " \
      --preview='bash -c '"'"'
printf "\033[2J\033[H"
path="$1"
echo "File: $path"
echo "Size: $(stat -c%s "$path" 2>/dev/null | numfmt --to=iec)"
echo ""
chafa -s 50x25 "$path" 2>/dev/null
'"'"' _ {4}' \
      --preview-window=right:50%:wrap \
      --header="TAB multi | ESC=back | sorted by size")

  local fzf_exit=$?
  
  if [[ $fzf_exit -eq 130 ]]; then
    rm -f "$LIST_FILE"
    main
    return
  fi
  
  [[ -z "$SELECTED" ]] && exit 0

  # Collect selected files
  local file_list=()
  while IFS=$'\t' read -r bytes size meta path; do
    [[ -z "$path" ]] && continue
    file_list+=("$path")
  done <<< "$SELECTED"
  
  # Confirm batch operation
  echo ""
  echo "  Will process ${#file_list[@]} file(s) with:"
  if [[ -n "$RUN_SCRIPT" ]]; then
    echo "    Tool: $tool_choice"
    echo "    Operation: $SCRIPT_OPERATION"
  else
    echo "    Action: Compress ($COMPRESS_MODE mode)"
  fi
  echo ""
  read -rp "  Proceed? [Y/n] " ans
  if [[ "$ans" =~ ^[Nn]$ ]]; then
    echo "  Cancelled."
    rm -f "$LIST_FILE"
    exit 0
  fi

  # Process files
  echo ""
  local i=0
  for path in "${file_list[@]}"; do
    (( i++ )) || true
    printf "  (%d/%d) " "$i" "${#file_list[@]}"
    
    if [[ -n "$RUN_SCRIPT" ]]; then
      # Pass operation to imgops script - FILE MUST BE FIRST ARGUMENT
      "$RUN_SCRIPT" "$path" --operation "$SCRIPT_OPERATION" "${EXTRA_ARGS[@]}"
    else
      compress_image "$path" "$COMPRESS_MODE"
    fi
  done

  rm -f "$LIST_FILE"
  echo ""
  echo "  Done."
  echo ""
  
  read -rp "  Press Enter to continue or 'q' to quit: " ans
  if [[ "$ans" != "q" ]]; then
    main
  fi
}

main "$@"
