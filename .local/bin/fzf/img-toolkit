#!/usr/bin/env bash
set -euo pipefail

TMP_DIR="/tmp/img-toolkit"
mkdir -p "$TMP_DIR"

# ── YOUR EXTERNAL SCRIPTS ─────────────────────────────────────────────────────
SCRIPT1="imgops"                    
CAPTION1="📷  Image Operations"

SCRIPT2="img-converter"             
CAPTION2="🔄  Convert Images"

SCRIPT3="img-uploader"              
CAPTION3="☁️  Upload to Cloud"

# ── helpers ───────────────────────────────────────────────────────────────────
die()  { echo "✗ $*" >&2; exit 1; }
info() { echo "  $*"; }

for cmd in fzf chafa trash numfmt stat magick; do
  command -v "$cmd" &>/dev/null || die "Required tool not found: $cmd"
done

# ── compress function ─────────────────────────────────────────────────────────
compress_image() {
  local path="$1" mode="$2"
  [[ -f "$path" ]] || { info "skipping (gone): $path"; return; }

  local base="${path%.*}"
  local ext="${path##*.}"
  local out="$path"
  
  [[ "$mode" == "new file" ]] && out="${base}-small.${ext}"
  
  local tmp="${TMP_DIR}/$(basename "$base")-tmp.${ext}"
  
  if [[ "$mode" == "smart" ]]; then
    case "$ext" in
      png)
        magick "$path" -resize 2560x1440\> -strip "$tmp"
        command -v oxipng &>/dev/null && oxipng -o 4 --strip all "$tmp" >/dev/null || true
        ;;
      jpg|jpeg)
        magick "$path" -resize 2560x1440\> -strip -quality 85 "$tmp"
        ;;
      webp)
        magick "$path" -resize 2560x1440\> -strip -quality 85 "$tmp"
        ;;
      *)
        magick "$path" -resize 2560x1440\> -strip "$tmp"
        ;;
    esac
  else
    magick "$path" -resize 2560x1440\> -strip "$tmp"
    if [[ "$ext" == "png" ]]; then
      command -v oxipng &>/dev/null && oxipng -o 4 --strip all "$tmp" >/dev/null || true
    fi
  fi
  
  mv "$tmp" "$out"
  
  local before=$(stat -c%s "$path")
  local after=$(stat -c%s "$out")
  local pct=0
  [[ "$before" -gt 0 ]] && pct=$(( (before - after) * 100 / before ))
  info "$(basename "$path")  $(numfmt --to=iec "$before") → $(numfmt --to=iec "$after")  (-${pct}%)"
  
  if [[ "$mode" == "trash original" && "$out" != "$path" ]]; then
    trash "$path"
    info "  (original trashed)"
  fi
}

# ── safe fzf wrapper with ESC handling ────────────────────────────────────────
fzf_menu() {
  local prompt="$1"
  shift
  local choices=("$@")
  
  local choice
  choice=$(printf '%s\n' "${choices[@]}" | fzf --prompt="$prompt" --height=40% --reverse)
  local exit_code=$?
  
  if [[ $exit_code -eq 130 ]] || [[ -z "$choice" ]]; then
    return 130  # ESC pressed
  fi
  
  echo "$choice"
  return 0
}

# ── select files function (returns to menu on ESC) ────────────────────────────
select_files() {
  local LIST_FILE="$1"
  
  local SELECTED
  SELECTED=$(cat "$LIST_FILE" | \
    fzf --multi \
      --delimiter=$'\t' \
      --with-nth=2.. \
      --prompt="Pick images (ESC=back) > " \
		  # --preview='fzf-chafa-preview.sh {}' \
      --preview='fzf-preview.sh {}' \
      --preview-window=right:50%:wrap \
      --header="TAB multi | ESC=back to menu")
  
  local fzf_exit=$?
  
  # ESC pressed (130) - return special code
  if [[ $fzf_exit -eq 130 ]]; then
    return 130
  fi
  
  # Return selected files
  local files=()
  while IFS=$'\t' read -r bytes size meta path; do
    [[ -z "$path" ]] && continue
    files+=("$path")
  done <<< "$SELECTED"
  
  printf '%s\n' "${files[@]}"
}

# ── main browser ──────────────────────────────────────────────────────────────
main() {
  # Get starting path from argument or use current directory
  local start_path="${1:-.}"
  
  # Convert to absolute path
  if [[ "$start_path" == "." ]]; then
    start_path="$(pwd)"
  elif [[ "$start_path" == "~"* ]]; then
    start_path="${HOME}${start_path:1}"
  fi
  
  # Validate path exists
  if [[ ! -d "$start_path" ]]; then
    die "Directory not found: $start_path"
  fi
  
  while true; do
    echo ""
    echo "  🖼️  Image Toolkit - Working in: $(basename "$start_path")"
    echo "  Path: $start_path"
    echo ""
    
    # Show available tools
    echo "  Available tools:"
    
    local script_cmds=()
    local script_captions=()
    
    for i in {1..99}; do
      local caption_var="CAPTION$i"
      local script_var="SCRIPT$i"
      if [[ -n "${!caption_var:-}" ]] && [[ -n "${!script_var:-}" ]]; then
        if command -v "${!script_var}" &>/dev/null; then
          echo "    ✓ ${!caption_var}"
          script_captions+=("${!caption_var}")
          script_cmds+=("${!script_var}")
        else
          echo "    ✗ ${!caption_var} (command '${!script_var}' not found)"
        fi
      fi
    done
    echo "    ✓ Compress images"
    echo ""

    # Select tool with ESC handling
    local menu_options=()
    menu_options+=("${script_captions[@]}")
    menu_options+=("Compress images")
    menu_options+=("Exit")
    
    local tool_choice
    tool_choice=$(fzf_menu "Select tool > " "${menu_options[@]}")
    
    # ESC pressed
    if [[ $? -eq 130 ]]; then
      continue
    fi
    
    # Exit selected
    if [[ "$tool_choice" == "Exit" ]]; then
      echo "  Exiting..."
      exit 0
    fi
    
    local RUN_SCRIPT=""
    local COMPRESS_MODE=""
    
    # Check if it's a script
    for i in "${!script_captions[@]}"; do
      if [[ "${script_captions[$i]}" == "$tool_choice" ]]; then
        RUN_SCRIPT="${script_cmds[$i]}"
        break
      fi
    done
    
    # If compress was selected, ask for mode with ESC handling
    if [[ "$tool_choice" == "Compress images" ]]; then
      local compress_options=("smart" "overwrite" "new file" "trash original" "Back")
      COMPRESS_MODE=$(fzf_menu "Compression mode > " "${compress_options[@]}")
      
      # ESC pressed or Back
      if [[ $? -eq 130 ]] || [[ "$COMPRESS_MODE" == "Back" ]]; then
        continue  # Go back to tool menu
      fi
    fi
    
    # If running a script, ask for the specific operation with ESC handling
    local SCRIPT_OPERATION=""
    local EXTRA_ARGS=()
    
    if [[ -n "$RUN_SCRIPT" ]]; then
      echo ""
      local op_options=(
        "↻ Rotate 90°"
        "↺ Rotate -90°"
        "🔄 Flip horizontal"
        "🔄 Flip vertical"
        "🖼️ Convert to PNG"
        "📐 Resize 50%"
        "🌈 Grayscale"
        "✂️ Crop (interactive)"
        "💧 Blur"
        "✨ Sharpen"
        "🌞 Brighten"
        "🌑 Darken"
        "📝 Watermark"
        "📏 Border"
        "Back"
      )
      
      SCRIPT_OPERATION=$(fzf_menu "Select operation > " "${op_options[@]}")
      
      # ESC pressed or Back
      if [[ $? -eq 130 ]] || [[ "$SCRIPT_OPERATION" == "Back" ]]; then
        continue  # Go back to tool menu
      fi
      
      # For operations that need extra input, ask once here
      case "$SCRIPT_OPERATION" in
        "✂️ Crop (interactive)")
          echo ""
          echo "Enter crop geometry (e.g., 800x600+10+10):"
          echo "Format: WIDTHxHEIGHT+XOFFSET+YOFFSET"
          read -p "Geometry: " geometry
          if [[ -n "$geometry" ]]; then
            EXTRA_ARGS=("--crop-geom" "$geometry")
          else
            echo "  Cancelled, going back..."
            continue
          fi
          ;;
        "📝 Watermark")
          echo ""
          read -p "Enter watermark text: " watermark
          if [[ -n "$watermark" ]]; then
            EXTRA_ARGS=("--watermark-text" "$watermark")
          else
            echo "  Cancelled, going back..."
            continue
          fi
          ;;
      esac
    fi

    # File/folder selection with IMAGE PREVIEW (simplified)
    echo ""
    local INPUT
    INPUT=$(fzf --multi \
        --prompt="Select images/folders in $(basename "$start_path") (ESC=back) > " \
        --walker="dir,file" \
        --walker-root="$start_path" \
        --preview="if [ -d {} ]; then ls -la {} | head -20; else chafa -s 50x25 {} 2>/dev/null || file {}; fi" \
        --preview-window=right:50%:wrap)
    
    local fzf_exit=$?
    
    # ESC pressed
    if [[ $fzf_exit -eq 130 ]] || [[ -z "$INPUT" ]]; then
      continue  # Go back to operation/tool menu
    fi

    # Build file list (respects the starting path)
    local FILES=()
    for t in $INPUT; do
      if [[ -d "$t" ]]; then
        while IFS= read -r f; do
          FILES+=("$f")
        done < <(find "$t" -type f \( -iname "*.png" -o -iname "*.jpg" -o -iname "*.jpeg" -o -iname "*.webp" \))
      else
        # Only add if it's an image file
        if [[ "$t" =~ \.(png|jpg|jpeg|webp)$ ]]; then
          FILES+=("$t")
        fi
      fi
    done
    
    if [[ ${#FILES[@]} -eq 0 ]]; then
      echo "  No images found, going back..."
      continue
    fi

    # Build table
    local LIST_FILE=$(mktemp)
    for f in "${FILES[@]}"; do
      local bytes=$(stat -c%s "$f")
      local size_h=$(numfmt --to=iec "$bytes")
      local mb=$((bytes / 1024 / 1024))
      
      case "${f##*.}" in
        png) local est=$((mb / 3)) ;;
        jpg|jpeg) local est=$((mb / 2)) ;;
        webp) local est=$((mb / 2)) ;;
        *) local est=$((mb / 2)) ;;
      esac
      
      printf "%s\t%s\tMB:%s→~%s\t%s\n" "$bytes" "$size_h" "$mb" "$est" "$f"
    done | sort -nr > "$LIST_FILE"

    # Select specific files with ESC handling
    local selected_files
    mapfile -t selected_files < <(select_files "$LIST_FILE")
    local select_exit=$?
    
    rm -f "$LIST_FILE"
    
    # ESC pressed in file picker
    if [[ $select_exit -eq 130 ]]; then
      continue  # Go back to folder selection
    fi
    
    if [[ ${#selected_files[@]} -eq 0 ]]; then
      continue  # No files selected, go back
    fi
    
    # Confirm batch operation
    echo ""
    echo "  Will process ${#selected_files[@]} file(s) with:"
    if [[ -n "$RUN_SCRIPT" ]]; then
      echo "    Tool: $tool_choice"
      echo "    Operation: $SCRIPT_OPERATION"
    else
      echo "    Action: Compress ($COMPRESS_MODE mode)"
    fi
    echo ""
    read -rp "  Proceed? [Y/n] " ans
    if [[ "$ans" =~ ^[Nn]$ ]]; then
      echo "  Cancelled, going back..."
      continue
    fi

    # Process files
    echo ""
    local i=0
    for path in "${selected_files[@]}"; do
      (( i++ )) || true
      printf "  (%d/%d) " "$i" "${#selected_files[@]}"
      
      if [[ -n "$RUN_SCRIPT" ]]; then
        "$RUN_SCRIPT" "$path" --operation "$SCRIPT_OPERATION" "${EXTRA_ARGS[@]}"
      else
        compress_image "$path" "$COMPRESS_MODE"
      fi
    done

    echo ""
    echo "  ✓ Done processing ${#selected_files[@]} file(s)"
    echo ""
    
    # Ask to continue or go back to start
    read -rp "  Press Enter to continue or 'q' to quit: " ans
    if [[ "$ans" == "q" ]]; then
      echo "  Exiting..."
      exit 0
    fi
    # Otherwise loop continues to main menu
  done
}

main "$@"
