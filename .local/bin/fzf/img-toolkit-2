#!/usr/bin/env bash
set -euo pipefail

TMP_DIR="/tmp/img-toolkit"
mkdir -p "$TMP_DIR"

THRESHOLD_MB=5

# ---------------- MODE ----------------
MODE=$(printf "smart\noverwrite\nnew file\ntrash original\n" | fzf --prompt="Mode > ")
[[ -z "$MODE" ]] && exit 0

# ---------------- FILE COLLECTION ----------------
INPUT=$(fzf --multi --prompt="Select images/folders > " --walker=dir --preview='file {}')
[[ -z "$INPUT" ]] && exit 0

FILES=()

for t in $INPUT; do
  if [[ -d "$t" ]]; then
    while IFS= read -r f; do
      FILES+=("$f")
    done < <(find "$t" -type f \( -iname "*.png" -o -iname "*.jpg" -o -iname "*.jpeg" -o -iname "*.webp" \))
  else
    FILES+=("$t")
  fi
done

# ---------------- BUILD TABLE ----------------
LIST_FILE=$(mktemp)

for f in "${FILES[@]}"; do
  bytes=$(stat -c%s "$f")
  size_h=$(numfmt --to=iec "$bytes")
  mb=$((bytes / 1024 / 1024))

  # rough estimate
  case "${f##*.}" in
    png) est=$((mb / 3)) ;;
    jpg|jpeg) est=$((mb / 2)) ;;
    webp) est=$((mb / 2)) ;;
    *) est=$((mb / 2)) ;;
  esac

  printf "%s\t%s\tMB:%s→~%s\t%s\n" "$bytes" "$size_h" "$mb" "$est" "$f"
done | sort -nr > "$LIST_FILE"

# ---------------- FZF PICKER ----------------
SELECTED=$(cat "$LIST_FILE" | \
fzf --multi \
  --delimiter=$'\t' \
  --with-nth=2.. \
  --prompt="Pick images > " \
  --preview='bash -c '"'"'
path="$1"
echo "File: $path"
echo "Size: $(stat -c%s "$path" 2>/dev/null | numfmt --to=iec)"
echo ""
chafa -s 50x25 "$path"
'"'"' _ {4}' \
  --preview-window=right:50%:wrap \
  --header="TAB multi | CTRL-S big files (>5MB) | sorted by size")

# ---------------- PROCESS ----------------
process_image() {
  local path="$1"
  local mode="$2"

  base="${path%.*}"
  ext="${path##*.}"

  out="$path"
  [[ "$mode" == "new file" ]] && out="${base}-small.${ext}"

  tmp="${TMP_DIR}/$(basename "$base")-tmp.png"

  echo "Processing: $path"

  if [[ "$MODE" == "smart" ]]; then
    case "$ext" in
      png)
        magick "$path" -resize 2560x1440\> -strip "$tmp"
        oxipng -o 4 --strip all "$tmp" >/dev/null
        ;;
      jpg|jpeg)
        magick "$path" -resize 2560x1440\> -strip -quality 85 "$tmp"
        ;;
      webp)
        magick "$path" -resize 2560x1440\> -strip "$tmp"
        ;;
      *)
        magick "$path" -resize 2560x1440\> -strip "$tmp"
        ;;
    esac
  else
    magick "$path" -resize 2560x1440\> -strip "$tmp"

    if [[ "$ext" == "png" ]]; then
      oxipng -o 4 --strip all "$tmp" >/dev/null
    fi
  fi

  mv "$tmp" "$out"

  if [[ "$mode" == "trash original" && "$out" != "$path" ]]; then
    trash "$path"
  fi
}

# ---------------- RUN ----------------
while IFS=$'\t' read -r bytes size meta path; do
  [[ -z "$path" ]] && continue
  process_image "$path" "$MODE"
done <<< "$SELECTED"

echo "Done."
