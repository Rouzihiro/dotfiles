[options]
# Suppress built-in key bindings, and specify them explicitly in this config file.
suppress_default_binds = true

[aliases]
# Define aliases here. Any arguments passed to an alias are appended to the
# command.
# alias = command to run
set_wallpaper = exec swaybg -i "$imv_current_file" -m fill && pkill imv

[binds]
q = quit
<Escape> = quit

# Image navigation
<Left> = prev
<Right> = next
b = prev
n = next
<space> = next
k = pan 0, 30
j = pan 0, -30
h = pan -30, 0
l = pan 30, 0
gg = goto 1
<Shift+G> = goto -1

# Zooming
<Shift+plus> = zoom 2
i = zoom 2
<minus> = zoom -2
o = zoom -2

# Rotate Clockwise by 90 degrees
r = exec mogrify -rotate 90 "$imv_current_file"
# r = rotate by 90

# Other commands
y = exec echo -n "$imv_current_file" | wl-copy && notify-send "Copied" "$imv_current_file"
q = close
c = center
s = scaling next
f = fullscreen
<Shift+S> = upscaling next
a = zoom actual
R = reset

# w = set_wallpaper

# Print the current image file
# <Ctrl+p> = exec lp "$imv_current_file"

# Trash the current image and quit the viewer (recoverable from Trash)
<Ctrl+X> = exec trash-put -- "$imv_current_file"; quit

# Trash the current image and move to the next one
<Ctrl+x> = exec trash-put -- "$imv_current_file"; close
X = exec trash-put -- "$imv_current_file"; close

# Edit the current image in Satty and quit the viewer
# <Ctrl+e> = exec satty --filename "$imv_current_file" & ; quit
