#!/usr/bin/env zsh
# sync-config-to-dotfiles.zsh
#
# Syncs selected changed files from ~/.config into ~/dotfiles/config/.config.
# Uses fzf multi-select with live delta diff preview.
#
# Also syncs ~/.local/bin subdirectories into:
# ~/dotfiles/config/.local/bin
#
# Root-level files in ~/.local/bin are ignored intentionally.
# This avoids syncing manually built binaries.
#
# Also syncs ~/git/ and ~/.gitconfig into:
# ~/dotfiles/config/git/ and ~/dotfiles/config/.gitconfig

SOURCE_ROOT="$HOME/.config"
TARGET_ROOT="$HOME/dotfiles/config/.config"

BIN_SOURCE="$HOME/.local/bin"
BIN_TARGET="$HOME/dotfiles/config/.local/bin"

GIT_SRC="$HOME/git"
GIT_TGT="$HOME/dotfiles/config/git"

GITCONFIG_SRC="$HOME/.gitconfig"
GITCONFIG_TGT="$HOME/dotfiles/config/.gitconfig"

EXCLUDE_DIRS=(
"bat"
"BraveSoftware"
"coc"
"colors"
"dconf"
"enchant"
"evolution"
"eza"
"geary"
"glib-2.0"
"glow"
"go"
"golazo"
"ibus"
"kritadisplayrc"
"kritarc"
"kwalletrc"
"libfm"
"libreoffice"
"matplotlib"
"micro"
"menus"
"noctalia"
"pavucontrol.ini"
"procps"
"protonfixes"
"pulse"
"pywal"
"qalculate"
"qBittorrent"
"QtProject.conf"
"ripgrep"
"swappy"
"systemd"
"Thunar"
"tinymist"
"transmission"
"typlite"
"vlc"
"voxtype"
"waypaper"
"xdg-desktop-portal"
"xdg-terminal-exec"
"xfce4"
"xm1"
"xournalpp"
"zen"
"zorro"
)

EXCLUDE_FILES=(
  "alacritty/theme.toml"
  "broot/skins/current.toml"
  "btop/themes/current.theme"
  "evince/print-settings"
  "foot/current-theme.ini"
  "hypr/theme.conf"
  "i3blocks/config"
  "kitty/colors.conf"
  "lazygit/config.yml"
  "mako/config"
  "nvim/lua/theme.lua"
  "rofi/colors.rasi"
  "rofi/launcher.rasi"
  "starship.toml"
  "sway/config.d/bar"
  "sway/config.d/theme"
  "swaync/style.css"
  "swayosd/colors.css"
  "tmux/tmux-colors.conf"
	"tmux/tmux-bar.conf"
  "waybar/colors.css"
  "yazi/theme.toml"
  "yazi/yazi-2.toml"
)

[[ -d "$TARGET_ROOT" ]] || {
  print -ru2 -- "Missing target: $TARGET_ROOT"
  exit 1
}

command -v fzf >/dev/null || {
  print -ru2 -- "fzf not found"
  exit 1
}

# ─────────────────────────────────────────────
# CONFIG SYNC
# ─────────────────────────────────────────────

typeset -a exclude_args

for ex in "${EXCLUDE_DIRS[@]}"; do
  exclude_args+=(
    -path "$SOURCE_ROOT/$ex"
    -prune
    -o
  )
done

typeset -a all_files

all_files=("${(@f)$(
  find "$SOURCE_ROOT" -mindepth 1 \
    "${exclude_args[@]}" \
    -path '*/.git/*' -prune -o \
    -path '*/node_modules/*' -prune -o \
    -type f -print |
    sed "s|^$SOURCE_ROOT/||"
)}")

typeset -A excluded

for ex in "${EXCLUDE_FILES[@]}"; do
  excluded[$ex]=1
done

typeset -a diff_files

for rel in "${all_files[@]}"; do
  [[ -n "${excluded[$rel]:-}" ]] && continue

  src="$SOURCE_ROOT/$rel"
  tgt="$TARGET_ROOT/$rel"

  if [[ ! -f "$tgt" ]]; then
    diff_files+=("$rel")
    continue
  fi

  if ! cmp -s "$src" "$tgt"; then
    diff_files+=("$rel")
  fi
done

if (( ${#diff_files[@]} > 0 )); then
  PREVIEW_CMD='
rel={}
src="'"$SOURCE_ROOT"'/$rel"
tgt="'"$TARGET_ROOT"'/$rel"

if [[ -f "$tgt" ]]; then
  diff -u "$tgt" "$src" | delta --paging=never
else
  echo "NEW FILE"
  echo
  diff -u /dev/null "$src" | delta --paging=never
fi
'

  typeset -a selected

  selected=("${(@f)$(
    printf "%s\n" "${diff_files[@]}" |
    fzf \
      --multi \
      --height=90% \
      --layout=reverse \
      --prompt="select config files > " \
      --header="TAB select / ENTER confirm" \
      --preview="$PREVIEW_CMD" \
      --preview-window='right:60%,border-left'
  )}")

  if (( ${#selected[@]} > 0 )); then
    typeset -A declined_dirs
    typeset -a to_copy

    for rel in "${selected[@]}"; do
      src="$SOURCE_ROOT/$rel"
      tgt="$TARGET_ROOT/$rel"
      dir="${tgt:h}"

      if [[ ! -d "$dir" ]]; then
        if [[ -n "${declined_dirs[$dir]:-}" ]]; then
          continue
        fi

        print -rn -- "Create ${dir#$TARGET_ROOT/}? [y/N] "
        read -r ans

        if [[ "$ans" =~ ^[Yy]$ ]]; then
          mkdir -p "$dir"
        else
          declined_dirs[$dir]=1
          continue
        fi
      fi

      to_copy+=("$rel")
    done

    if (( ${#to_copy[@]} > 0 )); then
      print -r -- ""
      print -r -- "Files to copy:"
      print -r -- ""

      for f in "${to_copy[@]}"; do
        print -r -- "  $f"
      done

      print -r -- ""
      print -rn -- "Proceed? [y/N] "
      read -r confirm

      if [[ "$confirm" =~ ^[Yy]$ ]]; then
        for f in "${to_copy[@]}"; do
          cp -- "$SOURCE_ROOT/$f" "$TARGET_ROOT/$f"
          print -r -- "copied: $f"
        done
        print -r -- "Config sync done."
      else
        print -r -- "Config sync aborted."
      fi
    else
      print -r -- "Nothing selected."
    fi
  else
    print -r -- "Config files already in sync."
  fi
fi

# ─────────────────────────────────────────────
# LOCAL BIN SYNC
# ─────────────────────────────────────────────

print -r -- ""
print -r -- "━━━ Syncing ~/.local/bin subdirectories ━━━"

if [[ ! -d "$BIN_SOURCE" ]]; then
  print -r -- "Missing source: $BIN_SOURCE"
  exit 0
fi

mkdir -p "$BIN_TARGET"

typeset -a bin_dirs

for dir in "$BIN_SOURCE"/*(/N); do
  bin_dirs+=("${dir:t}")
done

if (( ${#bin_dirs[@]} == 0 )); then
  print -r -- "No ~/.local/bin subdirectories found."
else
  print -r -- ""
  print -r -- "Subdirectories to sync:"
  print -r -- ""

  for d in "${bin_dirs[@]}"; do
    print -r -- "  $d/"
  done

  print -r -- ""
  print -rn -- "Proceed? [y/N] "
  read -r bin_confirm

  if [[ "$bin_confirm" =~ ^[Yy]$ ]]; then
    for dir in "$BIN_SOURCE"/*(/N); do
      name="${dir:t}"
      mkdir -p "$BIN_TARGET/$name"
      rsync -a "$dir/" "$BIN_TARGET/$name/"
      print -r -- "synced: $name/"
    done
    print -r -- "Bin sync done."
  else
    print -r -- "Bin sync aborted."
  fi
fi

# ─────────────────────────────────────────────
# GIT CONFIG SYNC
# ─────────────────────────────────────────────

print -r -- ""
print -r -- "━━━ Syncing git config ━━━"

typeset -a git_diff_files=()

# ~/.gitconfig
if [[ -f "$GITCONFIG_SRC" ]]; then
  if [[ ! -f "$GITCONFIG_TGT" ]] || ! cmp -s "$GITCONFIG_SRC" "$GITCONFIG_TGT"; then
    git_diff_files+=(".gitconfig")
  fi
fi

# ~/git/ tree
if [[ -d "$GIT_SRC" ]]; then
  while IFS= read -r -d '' f; do
    rel="${f#$GIT_SRC/}"
    tgt="$GIT_TGT/$rel"

    if [[ ! -f "$tgt" ]] || ! cmp -s "$f" "$tgt"; then
      git_diff_files+=("$rel")
    fi
  done < <(find "$GIT_SRC" -type f -print0)
fi

if (( ${#git_diff_files[@]} == 0 )); then
  print -r -- "Git config already in sync."
else
  GIT_PREVIEW_CMD='
rel={}
if [[ "$rel" == ".gitconfig" ]]; then
  src="'"$GITCONFIG_SRC"'"
  tgt="'"$GITCONFIG_TGT"'"
else
  src="'"$GIT_SRC"'/$rel"
  tgt="'"$GIT_TGT"'/$rel"
fi

if [[ -f "$tgt" ]]; then
  diff -u "$tgt" "$src" | delta --paging=never
else
  echo "NEW FILE"
  echo
  diff -u /dev/null "$src" | delta --paging=never
fi
'

  typeset -a git_selected=()

  git_selected=("${(@f)$(
    printf "%s\n" "${git_diff_files[@]}" |
    fzf \
      --multi \
      --height=90% \
      --layout=reverse \
      --prompt="select git files > " \
      --header="TAB select / ENTER confirm" \
      --preview="$GIT_PREVIEW_CMD" \
      --preview-window='right:60%,border-left'
  )}")

  if (( ${#git_selected[@]} > 0 )); then
    print -r -- ""
    print -r -- "Files to copy:"
    print -r -- ""

    for f in "${git_selected[@]}"; do
      print -r -- "  $f"
    done

    print -r -- ""
    print -rn -- "Proceed? [y/N] "
    read -r git_confirm

    if [[ "$git_confirm" =~ ^[Yy]$ ]]; then
      for f in "${git_selected[@]}"; do
        if [[ "$f" == ".gitconfig" ]]; then
          cp -- "$GITCONFIG_SRC" "$GITCONFIG_TGT"
        else
          tgt="$GIT_TGT/$f"
          mkdir -p "${tgt:h}"
          cp -- "$GIT_SRC/$f" "$tgt"
        fi
        print -r -- "copied: $f"
      done
      print -r -- "Git sync done."
    else
      print -r -- "Git sync aborted."
    fi
  else
    print -r -- "Git config already in sync."
  fi
fi
