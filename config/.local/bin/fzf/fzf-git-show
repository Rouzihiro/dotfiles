#!/usr/bin/env bash
# git-show — interactive fzf commit browser
# Keybinds (shown in fzf header):
#   enter    → file list for commit (--stat)
#   ctrl-d   → full diff for commit
#   ctrl-y   → yank commit hash to clipboard
#   ctrl-p   → cherry-pick commit
#   ctrl-r   → revert commit (creates revert commit)
#   ctrl-l   → view full commit log message

set -euo pipefail

# ── helpers ──────────────────────────────────────────────────────────────────

die() { printf '\e[31merror:\e[0m %s\n' "$*" >&2; exit 1; }

require() {
    for cmd in "$@"; do
        command -v "$cmd" &>/dev/null || die "'$cmd' not found in PATH"
    done
}

in_git_repo() {
    git rev-parse --git-dir &>/dev/null || die "not inside a git repository"
}

# Pretty commit format for the top-level picker
LOG_FORMAT='%C(yellow)%h%C(reset) %C(cyan)%ad%C(reset) %C(green)%<(16,trunc)%an%C(reset)  %s%C(auto)%d'

fzf_base() {
    fzf \
        --ansi \
        --no-sort \
        --layout=reverse \
        --border=rounded \
        --color='bg:#1d2021,bg+:#282828,fg:#ebdbb2,fg+:#fbf1c7,hl:#fabd2f,hl+:#fabd2f,border:#504945,header:#83a598,prompt:#fb4934,pointer:#fb4934,info:#8ec07c' \
        "$@"
}

yank() {
    local text="$1"
    if command -v wl-copy &>/dev/null; then
        printf '%s' "$text" | wl-copy
    elif command -v xclip &>/dev/null; then
        printf '%s' "$text" | xclip -selection clipboard
    elif command -v xsel &>/dev/null; then
        printf '%s' "$text" | xsel --clipboard --input
    else
        die "no clipboard tool found (wl-copy / xclip / xsel)"
    fi
}

# ── file-level actions ────────────────────────────────────────────────────────
# Called after the user picks a file from a commit's --stat listing.

file_actions() {
    local hash="$1" file="$2"

    local action
    action=$(printf '%s\n' \
        "󰈚  diff        — what changed in this commit" \
        "   open nvim  — view the file at this commit in nvim" \
        "   compare    — vimdiff: commit vs working tree" \
        "   blame      — git blame at this commit" \
        "   history    — commits that touched this file" \
        "   back       — ↩ return to file list" \
        | fzf_base \
            --prompt="$hash  $file  " \
            --header="enter: select  esc: back" \
            --with-nth=1 \
    ) || return 0

    case "$action" in
        *"diff"*)
            git show "$hash" -- "$file" \
                | fzf_base \
                    --prompt="diff $hash $file  " \
                    --header="esc: back  q: quit" \
                    --disabled \
                    --preview-window=hidden \
                    --bind="esc:abort,q:abort" \
                    || true
            file_actions "$hash" "$file"
            ;;
        *"open nvim"*)
            # Check out the file to a temp location then open
            local tmp
            tmp=$(mktemp --suffix="-$(basename "$file")")
            git show "$hash:$file" > "$tmp" 2>/dev/null \
                || { die "file '$file' not found in $hash"; return; }
            nvim "$tmp"
            rm -f "$tmp"
            file_actions "$hash" "$file"
            ;;
        *"compare"*)
            if [[ ! -f "$file" ]]; then
                die "working tree file not found: $file"
            fi
            local tmp
            tmp=$(mktemp --suffix="-$(basename "$file")")
            git show "$hash:$file" > "$tmp" 2>/dev/null \
                || { die "file '$file' not found in $hash"; return; }
            nvim -d "$tmp" "$file"
            rm -f "$tmp"
            file_actions "$hash" "$file"
            ;;
        *"blame"*)
            git blame "$hash" -- "$file" \
                | fzf_base \
                    --prompt="blame $hash $file  " \
                    --header="esc: back" \
                    --disabled \
                    --bind="esc:abort" \
                    || true
            file_actions "$hash" "$file"
            ;;
        *"history"*)
            # Recursive: browse commits that touched this file
            local sub_hash
            sub_hash=$(git log --color=always \
                --pretty="tformat:${LOG_FORMAT}" \
                --date=short \
                -- "$file" \
                | fzf_base \
                    --prompt="history: $file  " \
                    --header="enter: file list  esc: back" \
                    --preview="git show --stat --color=always {1}" \
                    --preview-window="right:50%:wrap" \
            ) || { file_actions "$hash" "$file"; return; }
            sub_hash=$(awk '{print $1}' <<< "$sub_hash")
            commit_files "$sub_hash"
            ;;
        *"back"*)
            return 0
            ;;
    esac
}

# ── commit → file list ────────────────────────────────────────────────────────

commit_files() {
    local hash="$1"

    # Files changed in this commit, with status prefix (M/A/D/R…)
    local file
    file=$(git diff-tree --no-commit-id -r --name-status "$hash" \
        | awk '{
            status=$1; file=$2
            if      (status ~ /^M/) icon="  "
            else if (status ~ /^A/) icon="  "
            else if (status ~ /^D/) icon="  "
            else if (status ~ /^R/) icon="  "
            else                    icon="   "
            print icon file
          }' \
        | fzf_base \
            --prompt="$hash  " \
            --header="enter: actions  ctrl-d: full diff  ctrl-s: --stat  esc: back" \
            --preview="git show --color=always $hash -- {2}" \
            --preview-window="right:55%:wrap" \
            --bind="ctrl-d:execute(git show --color=always $hash | less -R)" \
            --bind="ctrl-s:execute(git show --stat --color=always $hash | less -R)" \
    ) || return 0

    # Strip icon prefix to get bare filename
    local bare_file
    bare_file=$(awk '{print $NF}' <<< "$file")

    file_actions "$hash" "$bare_file"
    # Loop back after returning from actions
    commit_files "$hash"
}

# ── commit-level actions ──────────────────────────────────────────────────────

commit_actions() {
    local hash="$1"

    local action
    action=$(printf '%s\n' \
        "  files      — browse changed files" \
        "  full diff  — git show (entire commit)" \
        "  stat       — --stat summary" \
        "  log msg    — full commit message" \
        "  yank hash  — copy $hash to clipboard" \
        "  cherry     — cherry-pick onto HEAD" \
        "  revert     — create revert commit" \
        "  back       — ↩ return to log" \
        | fzf_base \
            --prompt="$hash  " \
            --header="enter: select  esc: back to log" \
    ) || return 0

    case "$action" in
        *"files"*)
            commit_files "$hash"
            commit_actions "$hash"
            ;;
        *"full diff"*)
            git show --color=always "$hash" | less -R
            commit_actions "$hash"
            ;;
        *"stat"*)
            git show --stat --color=always "$hash" | less -R
            commit_actions "$hash"
            ;;
        *"log msg"*)
            git log -1 --format="%B" "$hash" | less -R
            commit_actions "$hash"
            ;;
        *"yank hash"*)
            yank "$hash"
            printf '\e[32m✓\e[0m yanked \e[33m%s\e[0m\n' "$hash"
            sleep 0.6
            commit_actions "$hash"
            ;;
        *"cherry"*)
            git cherry-pick "$hash"
            printf '\e[32m✓\e[0m cherry-picked \e[33m%s\e[0m\n' "$hash"
            ;;
        *"revert"*)
            git revert --no-edit "$hash"
            printf '\e[32m✓\e[0m reverted \e[33m%s\e[0m\n' "$hash"
            ;;
        *"back"*)
            return 0
            ;;
    esac
}

# ── main log picker ───────────────────────────────────────────────────────────

main() {
    in_git_repo
    require git fzf nvim

    # Optional: branch/path filter from CLI args
    local log_args=("$@")

    while true; do
        local selection
        selection=$(git log \
            --color=always \
            --pretty="tformat:${LOG_FORMAT}" \
            --date=short \
            "${log_args[@]}" \
            | fzf_base \
                --prompt="commit  " \
                --header=$'enter: actions   ctrl-d: full diff   ctrl-f: browse files   ctrl-y: yank hash   ctrl-l: log msg\n ctrl-b: toggle branch view   esc/q: quit' \
                --preview="git show --stat --color=always {1}" \
                --preview-window="right:45%:wrap" \
                --bind="ctrl-d:execute(git show --color=always {1} | less -R)" \
                --bind="ctrl-f:execute($0 --files {1})" \
                --bind="ctrl-y:execute-silent(printf '%s' {1} | $(command -v wl-copy || command -v xclip || echo cat))" \
                --bind="ctrl-l:execute(git log -1 --format='%B' {1} | less -R)" \
                --bind="ctrl-b:reload(git log --color=always --all --graph --pretty='tformat:${LOG_FORMAT}' --date=short)" \
                --bind="q:abort,esc:abort" \
        ) || break

        local hash
        hash=$(awk '{print $1}' <<< "$selection")
        # Strip color codes if any leaked through
        hash=$(printf '%s' "$hash" | sed 's/\x1b\[[0-9;]*m//g')

        commit_actions "$hash"
    done
}

# ── entry point ───────────────────────────────────────────────────────────────

# Internal call: jump straight to file browser for a given hash
if [[ "${1:-}" == "--files" ]]; then
    commit_files "${2:?hash required}"
    exit 0
fi

main "$@"
