#!/usr/bin/env bash
DIR="$HOME/Documents/Notes"
mkdir -p "$DIR"

# Choose terminal dynamically
term="${TERMINAL:-foot}"
if ! command -v "$term" >/dev/null 2>&1; then
    term=$(command -v kitty || command -v alacritty || command -v wezterm || command -v xterm)
fi

open_in_term() {
    local file="$1"
    # Use hyprctl for Hyprland
    if command -v hyprctl >/dev/null 2>&1; then
        # Hyprland: Use hyprctl dispatch exec
        hyprctl dispatch exec "'$term' --title floaty-medium -e nvim '$file'"
    elif command -v swaymsg >/dev/null 2>&1; then
        # Sway fallback
        swaymsg exec "'$term' --title floaty-medium -e nvim '$file'"
    else
        # Fallback to just running in current terminal or background
        "$term" --title floaty-medium -e nvim "$file" &
    fi
}

# Get list of .md files
entries=$(find "$DIR" -maxdepth 1 -type f -name "*.md" -printf "📝 %f\n" | sort)

# Add create and delete options
options="$(printf '📄 Create New Note\n🗑️ Delete Note\n%s' "$entries")"

# Launch fzf
selection=$(printf '%s\n' "$options" | fzf \
    --height=40% \
    --layout=reverse \
    --border \
    --prompt='🗒 Notes> ')

[ -z "$selection" ] && exit

if [[ "$selection" == "📄 Create New Note" ]]; then
    new_name=$(printf '' | fzf \
        --height=40% \
        --layout=reverse \
        --border \
        --prompt='New note name (no .md): ' \
        --print-query | head -1)
    [ -z "$new_name" ] && exit
    file="$DIR/$new_name.md"
    [ -e "$file" ] || touch "$file"
    open_in_term "$file"
    exit
fi

if [[ "$selection" == "🗑️ Delete Note" ]]; then
    delete_target=$(find "$DIR" -maxdepth 1 -type f -name "*.md" -printf "📝 %f\n" | sort | fzf \
        --height=40% \
        --layout=reverse \
        --border \
        --prompt='🗑 Select note to delete: ')
    [ -z "$delete_target" ] && exit
    filename="${delete_target#📝 }"
    confirm=$(printf 'No\nYes' | fzf \
        --height=40% \
        --layout=reverse \
        --border \
        --prompt="Delete $filename? ")
    [[ "$confirm" == "Yes" ]] || exit
    rm -f "$DIR/$filename"
    exit
fi

filename="${selection#📝 }"
open_in_term "$DIR/$filename"
