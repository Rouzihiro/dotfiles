#!/bin/bash
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: $0 <file|dir>..."
  echo "Example: $0 *.mp4"
  exit 1
fi

# ---------------- COLLECT TARGET FILES ----------------
targets=()

for arg in "$@"; do
  if [[ -f "$arg" ]]; then
    targets+=("$arg")

  elif [[ -d "$arg" ]]; then
    # only top-level files in directory
    while IFS= read -r f; do
      targets+=("$f")
    done < <(find "$arg" -maxdepth 1 -type f)

  else
    echo "Skipping invalid path: $arg"
  fi
done

if [[ ${#targets[@]} -eq 0 ]]; then
  echo "No valid files found."
  exit 1
fi

echo "Running fix-mp4 on:"
printf ' - %s\n' "${targets[@]}"
echo

# ---------------- RUN PROCESSOR ----------------
fix-mp4 "${targets[@]}"

echo "Waiting 2 seconds..."
sleep 2

# ---------------- VALIDATE OUTPUTS ----------------
processed=()

for f in "${targets[@]}"; do
  dir="$(dirname "$f")"
  base="$(basename "$f")"
  fixed="${dir}/fixed_${base}"

  if [[ -f "$fixed" ]]; then
    processed+=("$f")
  else
    echo "WARNING: missing output for $f"
  fi
done

if [[ ${#processed[@]} -eq 0 ]]; then
  echo "No files were successfully processed. Aborting."
  exit 1
fi

# ---------------- CONFIRM ----------------
echo
echo "The following files will be trashed:"
printf ' - %s\n' "${processed[@]}"
echo

read -p "Proceed? [y/N]: " confirm
if [[ "${confirm,,}" != "y" ]]; then
  echo "Aborted."
  exit 0
fi

# ---------------- TRASH ORIGINALS ----------------
echo "Trashing originals..."
for f in "${processed[@]}"; do
  trash "$f"
done

echo "Waiting 2 seconds..."
sleep 2

# ---------------- RESTORE NAMES ----------------
echo "Renaming processed files..."

for f in "${processed[@]}"; do
  dir="$(dirname "$f")"
  base="$(basename "$f")"

  mv -- "${dir}/fixed_${base}" "$f"
done

echo "Done."
