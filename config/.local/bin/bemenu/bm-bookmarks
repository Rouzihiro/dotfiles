#!/bin/sh
set -eu
# --------------------------
# Bookmark files
# --------------------------
BOOKMARK_FILES="
$HOME/Documents/Notes/gaming.md
$HOME/Documents/Notes/xxx.md
$HOME/Documents/Notes/coding.md
$HOME/Documents/Notes/movies.md
$HOME/Documents/Notes/work.md
$HOME/Documents/Notes/torrent.md
"
# --------------------------
# dmenu appearance
# --------------------------
DMENU_OPTS="-l 30 -p links:"
# --------------------------
# Browser
# --------------------------
BROWSER="$(command -v zen-browser || true)"
FALLBACK="$(command -v xdg-open || echo zen-browser)"
# --------------------------
# Emit bookmark lines (hide URLs, skip comments)
# --------------------------
emit() {
    tag="$1"
    file="$2"
    [ -f "$file" ] || return 0
    grep -vE '^\s*(#|$)' "$file" | while IFS= read -r line; do
        case "$line" in
            *"::"*)
                title="${line%%::*}"
                url="${line#*::}"
                title="$(printf '%s' "$title" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')"
                url="$(printf '%s' "$url" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')"
                ;;
            *)
                url="$line"
                title="$(printf '%s' "$url" | sed -E 's#https?://##; s#^www\.##; s#/.*$##; s/\.(com|org|net|de|io|co)$//')"
                ;;
        esac
        printf '[%s] [%s]\t%s\n' "$tag" "$title" "$url"
    done
}
# --------------------------
# Build combined list and show bemenu
# --------------------------
choice="$({
    for f in $BOOKMARK_FILES; do
        tag="$(basename "$f" .md)"
        emit "$tag" "$f"
    done
} | sort | cut -f1 | ~/.local/bin/bemenu/bm-run $DMENU_OPTS || true)"

[ -n "$choice" ] || exit 0
# --------------------------
# Find full line with URL for chosen entry
# --------------------------
full_line="$({
    for f in $BOOKMARK_FILES; do
        tag="$(basename "$f" .md)"
        emit "$tag" "$f"
    done
} | sort | grep -F "$choice" || true)"

[ -n "$full_line" ] || exit 1

url="$(printf '%s' "$full_line" | cut -f2-)"
url="$(printf '%s' "$url" \
    | sed -e 's/[[:space:]]\+#.*$//' -e 's/[[:space:]]\/\/.*$//' \
          -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"

tag="$(printf '%s' "$choice" | sed -n 's/\[\(.*\)\] \[.*\]/\1/p')"

case "$url" in
    http://*|https://*|file://*|about:*) ;;
    *) url="https://$url" ;;
esac
# --------------------------
# Open in zen-browser
# --------------------------
nohup "$BROWSER" "$url" >/dev/null 2>&1 &
