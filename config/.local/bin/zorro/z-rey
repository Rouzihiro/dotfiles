#!/bin/bash
# zorro menu launcher - TTY version with fzf
export PATH="$HOME/.local/share/bin:$PATH"
export XDG_CONFIG_HOME="$HOME/.config"

BACK_TO_EXIT=false

### Utility functions
back_to() {
    local parent_menu="$1"
    if [[ "$BACK_TO_EXIT" == "true" ]]; then
        exit 0
    elif [[ -n "$parent_menu" ]]; then
        "$parent_menu"
    else
        show_main_menu
    fi
}

# New fzf-based menu function (replaces wofi)
menu() {
    local prompt="$1"
    local options="$2"
    local preselect="$3"
    
    # Convert newlines to fzf format
    local fzf_options="--prompt=\"$prompt: \" --height=40% --border --cycle"
    
    # Add preselect if provided
    if [[ -n "$preselect" ]]; then
        fzf_options="$fzf_options --query=\"$preselect\""
    fi
    
    # Use fzf to select option
    echo -e "$options" | eval "fzf $fzf_options" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//'
}

# TTY-friendly terminal launcher
terminal() {
    if [[ -n "$DISPLAY" ]] || [[ -n "$WAYLAND_DISPLAY" ]]; then
        xdg-terminal-exec --app-id=zorro "$@"
    else
        # In pure TTY, just run in current terminal
        "$@"
    fi
}

# Present terminal with optional message (adapted for TTY)
present_terminal() {
    local cmd="$1"
    if [[ -n "$DISPLAY" ]] || [[ -n "$WAYLAND_DISPLAY" ]]; then
        z-launch-floating-terminal-with-presentation "$cmd"
    else
        echo "Running in TTY mode..."
        eval "$cmd"
        echo "Press Enter to continue..."
        read
    fi
}

# Editor for TTY
open_in_editor() {
    echo "Editing: $1"
    if [[ -n "$DISPLAY" ]] || [[ -n "$WAYLAND_DISPLAY" ]]; then
        notify-send "Editing config file" "$1"
        z-launch-editor "$1"
    else
        # Use terminal editor in TTY
        ${EDITOR:-nano} "$1"
    fi
}

# Detect distro
if command -v pacman >/dev/null 2>&1; then
    DISTRO="ARCH"
elif command -v dnf >/dev/null 2>&1; then
    DISTRO="FEDORA"
else
    echo "Unsupported distro"
    exit 1
fi

install() {
    local name="$1"
    local pkg="$2"
    if [[ "$DISTRO" == "ARCH" ]]; then
        present_terminal "echo 'Installing $name...'; sudo pacman -S --noconfirm $pkg"
    else
        present_terminal "echo 'Installing $name...'; sudo dnf install -y $pkg"
    fi
}

install_and_launch() {
    local name="$1"
    local pkg="$2"
    local app="$3"
    if [[ "$DISTRO" == "ARCH" ]]; then
        present_terminal "echo 'Installing $name...'; sudo pacman -S --noconfirm $pkg && setsid gtk-launch $app"
    else
        present_terminal "echo 'Installing $name...'; sudo dnf install -y $pkg && setsid gtk-launch $app"
    fi
}

install_font() {
    local name="$1"
    local pkg="$2"
    local font="$3"
    if [[ "$DISTRO" == "ARCH" ]]; then
        present_terminal "echo 'Installing $name...'; sudo pacman -S --noconfirm --needed $pkg && sleep 2 && z-font-set '$font'"
    else
        present_terminal "echo 'Installing $name...'; sudo dnf install -y $pkg && sleep 2 && z-font-set '$font'"
    fi
}

install_terminal() {
    present_terminal "z-install-terminal $1"
}

