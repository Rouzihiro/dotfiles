show_theme_menu() {
  theme_list=$(z-theme-list 2>/dev/null)
  if [[ -z "$theme_list" ]]; then
    echo "No themes found"
    sleep 2
    back_to show_style_menu
    return
  fi
  
  theme=$(menu "Theme" "$theme_list\nBack" "$(z-theme-current 2>/dev/null)")
  if [[ "$theme" == "Back" || -z "$theme" ]]; then
    back_to show_style_menu
  else
    z-theme-set "$theme"
  fi
}

show_font_menu() {
  font_list=$(z-font-list 2>/dev/null)
  if [[ -z "$font_list" ]]; then
    echo "No fonts found"
    sleep 2
    back_to show_style_menu
