    back_to show_style_menu
  else
    z-font-set "$font"
  fi
}

show_setup_menu() {
  local options="Audio\nWifi\nBluetooth\nPower Profile\nMonitors"
  [ -f ~/.config/hypr/bindings.conf ] && options="$options\nKeybindings"
  [ -f ~/.config/hypr/input.conf ] && options="$options\nInput"
  options="$options\nDefaults\nDNS\nSecurity\nConfig\nBack"
  
  choice=$(menu "Setup" "$options")
  case "$choice" in
  "Audio") audio-switch ;;
  "Wifi")
    rfkill unblock wifi
		wifi
    ;;
  "Bluetooth")
    rfkill unblock bluetooth
    bt
    ;;
  "Power Profile") show_setup_power_menu ;;
  "Monitors") open_in_editor ~/.config/hypr/monitors.conf ;;
  "Keybindings") open_in_editor ~/.config/hypr/bindings.conf ;;
  "Input") open_in_editor ~/.config/hypr/input.conf ;;
  "Defaults") open_in_editor ~/.config/uwsm/default ;;
  "DNS") present_terminal z-setup-dns ;;
  "Security") show_setup_security_menu ;;
  "Config") show_setup_config_menu ;;
  "Back"|*) show_main_menu ;;
  esac
}

show_setup_power_menu() {
  profile_list=$(z-powerprofiles-list 2>/dev/null)
  if [[ -z "$profile_list" ]]; then
    echo "No power profiles found"
    sleep 2
    back_to show_setup_menu
    return
  fi
  
  profile=$(menu "Power Profile" "$profile_list\nBack" "$(powerprofilesctl get 2>/dev/null)")
  if [[ "$profile" == "Back" || -z "$profile" ]]; then
    back_to show_setup_menu
  else
    powerprofilesctl set "$profile"
  fi
}

