#!/usr/bin/env sh

SESSION_NAME="REY"

tmux has-session -t $SESSION_NAME 2>/dev/null || {

  # -------------------------
  # WINDOW 1: dotfiles + broot
  # -------------------------
  tmux new-session -d -s $SESSION_NAME -n "work"

  tmux send-keys -t $SESSION_NAME:1.1 'cd ~/dotfiles && br' C-m

  tmux split-window -v -t $SESSION_NAME:1 -p 20

  tmux select-pane -t $SESSION_NAME:1.1


  # -------------------------
  # WINDOW 2: nvim picker
  # -------------------------
	tmux new-window -t $SESSION_NAME:2 -n "recent" -c "$HOME/dotfiles"

  tmux send-keys -t $SESSION_NAME:2.1 \
    "nvim -c \"lua require('fzf-lua').oldfiles()\"" C-m

  tmux select-pane -t $SESSION_NAME:2.1


  # -------------------------
  # WINDOW 3: LIFE DASHBOARD
  # -------------------------
  tmux new-window -t $SESSION_NAME:3 -n "tasks"

  # split left/right
  tmux split-window -h -t $SESSION_NAME:3 -p 35

  # Pane layout:
  # 1 = Calcurse (top-left)
  # 2 = Notes (top-right)

  tmux send-keys -t $SESSION_NAME:3.1 "calcurse" C-m

  tmux send-keys -t $SESSION_NAME:3.2 \
		"cd ~/Documents/Notes && nvim ." C-m

	tmux select-window -t $SESSION_NAME:2
}

# Attach
tmux attach-session -t $SESSION_NAME
