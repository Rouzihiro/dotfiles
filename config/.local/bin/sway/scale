#!/bin/sh
[ -z "$1" ] && { echo "Usage: scale <value>"; exit 1; }

if hyprctl monitors -j >/dev/null 2>&1; then
    monitor=$(hyprctl monitors -j | jq -r '.[] | select(.focused) | .name')
    hyprctl keyword monitor "$monitor,preferred,auto,$1"
    gsettings set org.gnome.desktop.interface text-scaling-factor 1.5
elif swaymsg -t get_outputs >/dev/null 2>&1; then
    monitor=$(swaymsg -t get_outputs | jq -r '.[] | select(.focused) | .name')
    swaymsg output "$monitor" scale "$1"
else
    echo "Error: Neither Hyprland nor Sway detected"; exit 1
fi
