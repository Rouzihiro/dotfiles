separator=false
markup=pango
separator_block_width=10

[weather]
command=weather-short
interval=1000
color={{fg}}

[separator]
full_text="⟨"
color={{bg_subtle}}

[bandwidth]
command=bandwith
interval=1
label=   
color={{color6}}

[separator]
full_text="⟨"
color={{bg_subtle}}

[disk]
label=  
instance=/
command=df -h / | awk 'NR==2 {print $3 "/" $2}'
interval=30
color={{accent}}

[separator]
full_text="⟨"
color={{bg_subtle}}

[memory]
label=  
command=memory
interval=2
color={{accent}}

[separator]
full_text="⟨"
color={{bg_subtle}}

[cpu_usage]
label=  
command=cpu-usage
interval=2
color={{color1}}

[separator]
full_text="⟨"
color={{bg_subtle}}

[wifi]
command=wifi-status
interval=30
color={{fg}}

[separator]
full_text="⟨"
color={{bg_subtle}}

[volume]
command=sb-volume
interval=1
color={{color3}}

[separator]
full_text="⟨"
color={{bg_subtle}}

[power-profile]
command=power-wrapper
interval=5
signal=10
color={{fg}}

[separator]
full_text="⟨"
color={{bg_subtle}}

[brightness]
command=sb-brightness
interval=5
label=   
color={{fg}}

[separator]
full_text="⟨"
color={{bg_subtle}}

[time]
interval=1
command=timer
separator_block_width=10
label=  
color={{accent}}

[separator]
full_text="⟨"
color={{bg_subtle}}

[keymap]
command=kb-layout
interval=2
color={{accent}}

[separator]
full_text="⟨"
color={{bg_subtle}}

[battery]
command=battery
interval=30
color={{color6}}

[separator]
full_text="⟨"
color={{bg_subtle}}

[shutdown_menu]
full_text=
command=powermenu
color={{color1}}
