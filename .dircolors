# ===================================================================
# Terminal filters
# ===================================================================
COLORTERM ?*
TERM *color*
TERM *direct*
TERM xterm*
TERM screen*
TERM tmux*
TERM rxvt*
TERM st
TERM linux
TERM konsole
TERM kitty
TERM foot
TERM gnome
TERM wezterm

# ===================================================================
# Basic file attributes
# ===================================================================

RESET 0


DIR 01;38;2;215;204;200
LINK 01;38;2;188;170;164
MULTIHARDLINK 00
FIFO 48;2;62;39;35;38;2;215;204;200
SOCK 01;38;2;215;204;200
DOOR 01;38;2;215;204;200
BLK  48;2;62;39;35;38;2;188;170;164;01
CHR  48;2;62;39;35;38;2;188;170;164;01
ORPHAN 48;2;62;39;35;38;2;188;170;164;01
MISSING 00
SETUID 38;2;215;204;200;48;2;188;170;164
SETGID 38;2;62;39;35;48;2;215;204;200
CAPABILITY 00
STICKY_OTHER_WRITABLE 38;2;62;39;35;48;2;188;170;164
OTHER_WRITABLE       38;2;215;204;200;48;2;188;170;164
STICKY               38;2;215;204;200;48;2;215;204;200
EXEC 01;38;2;188;170;164

