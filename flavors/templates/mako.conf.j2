layer=overlay
anchor=top-right
margin=20,20,0,0
padding=16
border-radius=10
width=250
height=90
font=JetBrainsMono Nerd Font 16
background-color=#{{ palette_bg_subtle }}cc
text-color=#{{ palette_fg }}
border-color=#{{ palette_bg }}
border-size=3
progress-color=#{{ palette_warning }}

icons=1
max-icon-size=56
icon-border-radius=8
sort=-time
max-history=60
max-visible=5
markup=1
text-alignment=left
format=<span foreground="#{{ palette_fg }}" weight="bold">%s</span>\n<span foreground="#{{ palette_fg }}">%b</span>

default-timeout=6500
ignore-timeout=0

[urgency=low]
background-color=#{{ palette_sel_bg }}cc
text-color=#{{ palette_fg }}
border-color=#{{ palette_success }}
progress-color=#{{ palette_warning }}
default-timeout=3500

[urgency=normal]
background-color=#{{ palette_bg_subtle }}cc
text-color=#{{ palette_fg }}
border-color=#{{ palette_success }}
progress-color=#{{ palette_warning }}

[urgency=critical]
background-color=#{{ palette_bg_subtle }}cc
text-color=#{{ palette_fg }}
border-color=#{{ palette_error }}
progress-color=#{{ palette_error }}
default-timeout=0
ignore-timeout=1
