#!/bin/sh

# Function to enable external monitor only (HDMI-A-1)
enable_external_only() {
    swaymsg output eDP-1 disable
    swaymsg output HDMI-A-1 enable
    echo "External only setup enabled."
}

# Function to enable laptop monitor only (eDP-1)
enable_laptop_only() {
    swaymsg output eDP-1 enable
    swaymsg output HDMI-A-1 disable
    echo "Laptop only setup enabled."
}

# Function to enable dual monitors (both enabled)
enable_dual() {
    swaymsg output eDP-1 enable
    swaymsg output HDMI-A-1 enable
    echo "Dual monitor setup enabled."
}

# Prompt the user for their desired setup
echo "Select monitor setup:"
echo "1. External Only"
echo "2. Laptop Only"
echo "3. Dual"
echo "4. Exit"

# Read user input
read -p "Enter your choice (1/2/3/4): " choice

case "$choice" in
    1)
        enable_external_only
        ;;
    2)
        enable_laptop_only
        ;;
    3)
        enable_dual
        ;;
    4)
        echo "Exiting..."
        exit 0
        ;;
    *)
        echo "Invalid option. Exiting."
        exit 1
        ;;
esac

