#!/bin/sh

# Function to enable external monitor only (HDMI-A-1)
enable_external_only() {
    wlr-randr --output eDP-1 --off
    wlr-randr --output HDMI-A-1 --on
    echo "External only setup enabled."
}

# Function to enable laptop monitor only (eDP-1)
enable_laptop_only() {
    wlr-randr --output eDP-1 --on
    wlr-randr --output HDMI-A-1 --off
    echo "Laptop only setup enabled."
}

# Function to enable dual monitors (both enabled)
enable_dual() {
    wlr-randr --output eDP-1 --on
    wlr-randr --output HDMI-A-1 --on
    echo "Dual monitor setup enabled."
}

# Use wofi to prompt the user for their desired output setup
choice=$(echo -e "External Only\nLaptop Only\nDual" | wofi --dmenu --prompt="Select monitor setup:")

case "$choice" in
    "External Only")
        enable_external_only
        ;;
    "Laptop Only")
        enable_laptop_only
        ;;
    "Dual")
        enable_dual
        ;;
    *)
        echo "Invalid option. Exiting."
        exit 1
        ;;
esac

