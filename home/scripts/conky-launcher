#!/bin/sh

# Function to kill all Conky instances using the alias
kill_conky() {
    echo "Killing all running Conky instances..."
    pkill -f conky || echo "No running Conky instances to kill."
}

# Function to start a specific Conky configuration
start_conky() {
    config=$1
    echo "Starting Conky with configuration: $config"
    conky -c "$config" & disown
}

# Paths to Conky configurations
KEYBINDINGS_CONF=~/dotfiles/home/system/conky/keybindings-shell.conf
MAIN_RIGHT_CONF=~/dotfiles/home/system/conky/main-right.conf
NETWORK_CONF=~/dotfiles/home/system/conky/network.conf

# Menu prompt
while true; do
    echo "Choose an option:"
    echo "1) Kill all Conky instances"
    echo "2) Activate main-right Conky"
    echo "3) Activate keybindings-shell Conky"
    echo "4) Activate network Conky"
    echo "5) Do nothing and exit"
    echo -n "Enter your choice: "
    read -r choice

    case $choice in
        1)
            kill_conky
            ;;
        2)
            start_conky "$MAIN_RIGHT_CONF"
            ;;
        3)
            start_conky "$KEYBINDINGS_CONF"
            ;;
        4)
            start_conky "$NETWORK_CONF"
            ;;
        5)
            echo "Exiting script."
            break
            ;;
        *)
            echo "Invalid option. Please choose again."
            ;;
    esac
done

