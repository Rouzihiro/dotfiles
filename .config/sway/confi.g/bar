bar {
    position top
    tray_padding 0
    status_command i3blocks -c ~/.config/i3blocks/config
    separator_symbol ""
    font pango:DroidSansM Nerd Font 10
    
    colors {
        background 1E1E2E
        statusline CDD6F4
        separator  1E1E2E
        
        focused_workspace  CDD6F4      CDD6F4      1E1E2E
        active_workspace   CDD6F4      CDD6F4      1E1E2E
        inactive_workspace 1E1E2E      1E1E2E      87B0F9
        urgent_workspace   87B0F9  87B0F9  1E1E2E
        binding_mode       F5C2E7  F5C2E7  1E1E2E
    }
}
