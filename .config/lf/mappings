# vim:ft=conf
# Arrow keys navigation
map <up> up
map <down> down
map <left> updir
map <right> open
map o :context
map i :image-ops

map q quit
map k up
map j down
map h updir
map l open
map gg top
map G bottom
map K :updir; up; open
map J :updir; down; open
map x cut
map y copy
map Y copyToClipboard
map <c-y> :yankPath
map gn :yankFilename
map p :paste; clear
map P :pasteAsync
map L link
map v invert
map ] jump-next
map [ jump-prev
map f search
map F :fzfJump
# map / search
map e $$f # Execute the selected file, must be executable
map t $$SHELL
map r rename
map R bulkRename
map O &xdg-open $f
# map L lfrc
map | :set ratios 1:2
# map ` shell
# map ` selectRandom
map ; find-next
map , find-prev
map \% shell-pipe
map \! shell-wait
map \& shell-async
map \$ shell
map \' !true
map \\ :calcdirsize; down;

map <a-j> :push 5j
map <a-k> :push 5k
map <c-d> half-down
map <c-u> half-up
map <c-n> search-next
map <c-p> search-prev
map <c-r> :reload; redraw
map <c-c> :sourceConfig
map <c-f> :fzfSearch

map <enter> open
map <esc> push u
map <delete> delete
map <backspace2> clear
map <space> :toggle; down

map mp chmod #use 664, 777 notation rather than u+x
map mc mark-save
map mx chmodx
map ua unarchive
map bg setWallpaper
map du directorySize # Requires dua-cli utility
map dg dragAndDrop
map T $trash-put $fx
map D $rm -rf -- $fx

map . set hidden!
map zr set reverse!
map zn set info
map zs set info size
map zt set info time
map za set info size:time
map sn :set sortby natural; set info
map ss :set sortby size; set info size
map st :set sortby time; set info time
map sa :set sortby atime; set info atime
map sc :set sortby ctime; set info ctime
map se :set sortby ext; set info

# Bookmark Bindings
map gh cd ~
map gr cd /
map gw cd ~/Documents/
map gd cd ~/Downloads/
map gv cd ~/Videos/
map gc cd ~/.config/
map gp cd ~/Pictures/
map gt cd ~/.trash/
map gf cd ~/dotfiles/
map gl cd ~/.local/
map gu cd ~/mount/usb/
map gt cd ~/.local/share/Trash
